{
  "name": "auxo-homepage",
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=20.19.1 <25.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "astro dev --port 4340",
    "build": "astro build",
    "build:fast": "NODE_OPTIONS=\"--max-old-space-size=4096\" astro build",
    "build:check": "npm run lint && npm run build",
    "build:analyze": "npm run build && npx vite-bundle-analyzer dist/",
    "preview": "astro preview --port 4341",
    "type-check": "tsc --noEmit",
    "lint:css": "stylelint \"src/styles/**/*.css\" --allow-empty-input",
    "lint:css:fix": "stylelint \"src/styles/**/*.css\" --fix --allow-empty-input",
    "css:prune:report": "node scripts/css/prune-unused-css.mjs --aggressive --report reports/css-prune-report.json",
    "css:prune": "node scripts/css/prune-unused-css.mjs --write --aggressive --report reports/css-prune-report.json",
    "lint": "npm run type-check && npm run lint:css",
    "lint:fix": "npm run lint:css:fix",
    "validate": "npm run lint && npm run build:check",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:ci": "playwright test"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/tailwind": "^6.0.2",
    "@emailjs/browser": "^4.4.1",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/simple-icons": "^1.2.63",
    "astro": "^5.18.1",
    "astro-icon": "^1.1.5",
    "embla-carousel": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "focus-trap": "^8.0.1",
    "lenis": "^1.2.11",
    "web-vitals": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "autoprefixer": "^10.4.20",
    "cssnano": "^7.1.2",
    "postcss-preset-env": "^11.2.0",
    "purgecss": "^8.0.0",
    "sharp": "^0.34.5",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-config-tailwindcss": "^1.0.1",
    "stylelint-order": "^6.0.4",
    "tailwindcss": "^3.4.18",
    "terser": "^5.44.1",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "sharp": "^0.34.5",
    "prismjs": "^1.30.0"
  }
}
