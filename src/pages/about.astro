---
import BaseLayout from "@/layouts/BaseLayout.astro";
import StructuredData from "@/components/common/StructuredData.astro";
import HeroSection from "@/components/sections/about/HeroSection.astro";
import MissionVisionSection from "@/components/sections/about/MissionVisionSection.astro";
import PurposeSection from "@/components/sections/about/PurposeSection.astro";
import ApproachSection from "@/components/sections/about/ApproachSection.astro";
import TeamSection from "@/components/sections/about/TeamSection.astro";
import PartnershipSection from "@/components/sections/about/PartnershipSection.astro";
import GlobalSection from "@/components/sections/about/GlobalSection.astro";
import CtaSection from "@/components/sections/common/CtaSection.astro";
import { aboutContent } from "@/data/content";
import "@/styles/sections/hero.css";
import "@/styles/sections/about-sections.css";
import "@/styles/components/carousels.css";
import "@/styles/sections/carousel-sections.css";
import { createBreadcrumbSchema } from "@/lib/structuredData";

const breadcrumbSchema = createBreadcrumbSchema("/about", "About");
const sections = [
  { Component: HeroSection, props: { content: aboutContent.hero } },
  { Component: MissionVisionSection, props: { content: aboutContent.mission } },
  { Component: PurposeSection, props: { content: aboutContent.purpose } },
  { Component: ApproachSection, props: { content: aboutContent.approach } },
  { Component: TeamSection, props: { content: aboutContent.team } },
  {
    Component: PartnershipSection,
    props: { content: aboutContent.partnership },
  },
  { Component: GlobalSection, props: { content: aboutContent.global } },
] as const;
const ctaProps = {
  id: "about-cta",
  title: aboutContent.cta.title,
  titleHighlight: "Partnership",
  description: aboutContent.cta.description,
  descriptionHighlight: aboutContent.cta.descriptionHighlight,
  ctaText: aboutContent.cta.ctaText,
  ctaHref: aboutContent.cta.ctaHref,
  variant: "standard" as const,
  background: "default" as const,
  maxWidth: "4xl" as const,
  class: "about-cta-section",
};
---

<BaseLayout
  title="About Us | AUXO Data Labs"
  description="Learn about AUXO Data Labs - a modern decision intelligence partner that bridges business strategy and data execution. Discover our mission, vision, and approach."
>
  <StructuredData type="BreadcrumbList" data={breadcrumbSchema} />
  {sections.map(({ Component, props }) => <Component {...props} />)}
  <CtaSection {...ctaProps} />
</BaseLayout>
