---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ServiceHeroSection from "@/components/sections/services/ServiceHeroSection.astro";
import ServiceOverviewSection from "@/components/sections/services/ServiceOverviewSection.astro";
import ServiceBenefitsSection from "@/components/sections/services/ServiceBenefitsSection.astro";
import ServiceProcessSection from "@/components/sections/services/ServiceProcessSection.astro";
import ServiceOutcomesSection from "@/components/sections/services/ServiceOutcomesSection.astro";
import CtaSection from "@/components/sections/common/CtaSection.astro";
import {
  getServiceDetailBySlug,
  servicesContent,
} from "@/data/content";
import "@/styles/sections/hero.css";
import "@/styles/sections/services-individual.css";
import "@/styles/components/carousels.css";
import "@/styles/sections/carousel-sections.css";

const notFoundResponse = new Response(null, {
  status: 404,
  statusText: "Service not found",
});

export async function getStaticPaths() {
  return servicesContent.details.map((service) => ({
    params: { slug: service.slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  return notFoundResponse;
}

const service = getServiceDetailBySlug(slug);

if (!service) {
  return notFoundResponse;
}

const sections = [
  { Component: ServiceHeroSection, props: { service } },
  { Component: ServiceOverviewSection, props: { service } },
  { Component: ServiceBenefitsSection, props: { service } },
  { Component: ServiceProcessSection, props: { service } },
  { Component: ServiceOutcomesSection, props: { service } },
] as const;
const ctaProps = {
  id: "service-cta",
  title: service.cta.title,
  titleHighlight: service.cta.title.split(" ").slice(-3),
  description: service.cta.description,
  descriptionHighlight: service.cta.descriptionHighlight,
  ctaText: service.cta.ctaText,
  ctaHref: service.cta.ctaHref,
  variant: "elevated" as const,
  background: "elevated" as const,
  maxWidth: "4xl" as const,
  additionalInfo:
    "Ready to discuss your specific needs? Our team typically responds within 24 hours.",
  class: "service-cta-section",
};
---

<BaseLayout
  title={`${service.name} | AUXO Data Labs`}
  description={service.hero.description}
>
  <div data-service-name={service.name} class="relative">
    {sections.map(({ Component, props }) => <Component {...props} />)}
    <CtaSection {...ctaProps} />
  </div>

  <script>
    import "@/scripts/pages/serviceDetailPage";
  </script>
</BaseLayout>
