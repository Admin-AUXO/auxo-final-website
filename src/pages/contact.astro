---
import BaseLayout from "@/layouts/BaseLayout.astro";
import StructuredData from "@/components/common/StructuredData.astro";
import SectionShell from "@/components/layouts/SectionShell.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import BackgroundDecorations from "@/components/ui/BackgroundDecorations.astro";
import ContactForm from "@/components/forms/ContactForm.astro";
import HighlightText from "@/components/ui/HighlightText.astro";
import { contactContent, siteData } from "@/data/content";
import { Icon } from "astro-icon/components";
import { createBreadcrumbSchema } from "@/lib/structuredData";
import { createUrl } from "@/utils/url";
import "@/styles/sections/hero.css";
import "@/styles/sections/contact-sections.css";

const breadcrumbSchema = createBreadcrumbSchema("/contact", "Contact");

const contactCards = [
  {
    type: "link",
    label: "Email",
    value: siteData.email,
    href: `mailto:${siteData.email}`,
    icon: "mdi:email-outline",
  },
  {
    type: "static",
    label: "Location",
    value: `${siteData.address.city}, ${siteData.address.country}`,
    icon: "mdi:map-marker-outline",
  },
  {
    type: "static",
    label: "Response time",
    value: "Within 1 business day",
    icon: "mdi:clock-check-outline",
  },
  {
    type: "link",
    label: "LinkedIn",
    value: "AUXO Data Labs",
    href: siteData.social.linkedin,
    icon: "mdi:linkedin",
  },
] as const;
---

<BaseLayout
  title="Contact Us | AUXO Data Labs"
  description="Contact AUXO Data Labs to discuss reporting issues, analytics strategy, forecasting, automation, or embedded decision-intelligence support."
>
  <StructuredData type="BreadcrumbList" data={breadcrumbSchema} />

  <section id="contact-hero" class="contact-hero-section hero-section">
    <BackgroundDecorations gradients={["hero"]} patterns={["grid"]} />

    <div class="grid-container relative z-10">
      <div class="col-span-full max-w-6xl mx-auto text-center">
        <div
          class="contact-hero-badge"
          data-reveal="zoom-in"
          data-reveal-duration="200"
          data-reveal-easing="ease-out"
        >
          {contactContent.hero.eyebrow}
        </div>

        <h1
          class="contact-hero-title"
          data-reveal="fade-down"
          data-reveal-duration="200"
          data-reveal-easing="ease-out"
        >
          <HighlightText
            text={contactContent.hero.title}
            highlight={contactContent.hero.titleHighlight}
          />
        </h1>

        <p
          class="contact-hero-description"
          data-reveal="fade-up"
          data-reveal-delay="50"
          data-reveal-duration="200"
          data-reveal-easing="ease-out"
        >
          {contactContent.hero.description}
        </p>

        <div
          class="contact-hero-pills"
          data-reveal="fade-up"
          data-reveal-delay="80"
          data-reveal-duration="200"
          data-reveal-easing="ease-out"
        >
          {contactContent.hero.pills.map((pill) => (
            <span class="contact-hero-pill">{pill}</span>
          ))}
        </div>

        <div
          class="contact-hero-actions"
          data-reveal="fade-up"
          data-reveal-delay="100"
          data-reveal-duration="200"
          data-reveal-easing="ease-out"
        >
          <button
            type="button"
            data-google-calendar-open
            class="contact-primary-cta"
            aria-label="Schedule a meeting"
          >
            <Icon name="mdi:calendar-clock-outline" class="w-5 h-5" />
            <span>{contactContent.hero.primaryCtaText}</span>
          </button>

          <a href={contactContent.hero.secondaryCtaHref} class="contact-secondary-cta">
            {contactContent.hero.secondaryCtaText}
          </a>
        </div>
      </div>
    </div>
  </section>

  <SectionShell
    id="contact-use-cases"
    padding="normal"
    background="surface"
    gradients={["top"]}
    patterns={["mesh"]}
    contentWidth="6xl"
    class="relative contact-use-cases-section section-divider"
  >
    <SectionHeader
      title={contactContent.useCases.title}
      subtitle={contactContent.useCases.description}
    />

    <div class="contact-use-cases-grid">
      {contactContent.useCases.items.map((item, index) => (
        <article
          class="contact-use-case-card"
          data-reveal="fade-up"
          data-reveal-delay={index * 40}
          data-reveal-duration="200"
          data-reveal-easing="ease-out"
        >
          <div class="contact-use-case-icon">
            <Icon name={item.icon} class="w-6 h-6 text-accent-green" />
          </div>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </SectionShell>

  <SectionShell
    id="contact-form-section"
    padding="normal"
    background="default"
    gradients={["dual"]}
    patterns={["grid"]}
    contentWidth="6xl"
    class="relative contact-main-section section-divider"
  >
    <div class="contact-main-grid">
      <aside
        class="contact-sidebar"
        data-reveal="fade-right"
        data-reveal-duration="200"
        data-reveal-easing="ease-out"
      >
        <div class="contact-sidebar-panel">
          <p class="contact-sidebar-kicker">Before you hit send</p>
          <h2 class="contact-sidebar-title">{contactContent.formSection.title}</h2>
          <p class="contact-sidebar-copy">{contactContent.formSection.description}</p>

          <div class="contact-checklist">
            {contactContent.formSection.checklist.map((item) => (
              <div class="contact-checklist-item">
                <Icon name="mdi:check-bold" class="w-4 h-4 text-accent-green flex-shrink-0" />
                <span>{item}</span>
              </div>
            ))}
          </div>

          <p class="contact-sidebar-note">{contactContent.formSection.note}</p>
        </div>

        <div class="contact-details-panel">
          <div class="contact-details-head">
            <h3>Other ways to reach AUXO</h3>
            <button type="button" data-google-calendar-open class="contact-inline-schedule">
              <Icon name="mdi:calendar-clock-outline" class="w-4 h-4" />
              <span>Book time</span>
            </button>
          </div>

          <div class="contact-details-list">
            {contactCards.map((card) => {
              const Tag = card.type === "link" ? "a" : "div";

              return (
                <Tag
                  href={card.type === "link" ? card.href : undefined}
                  class={`contact-detail-card ${card.type === "link" ? "contact-detail-card-link" : ""}`}
                  target={card.type === "link" && card.href?.startsWith("http") ? "_blank" : undefined}
                  rel={card.type === "link" && card.href?.startsWith("http") ? "noreferrer" : undefined}
                >
                  <div class="contact-detail-icon">
                    <Icon name={card.icon} class="w-5 h-5 text-accent-green" />
                  </div>
                  <div class="contact-detail-copy">
                    <span class="contact-detail-label">{card.label}</span>
                    <span class="contact-detail-value">{card.value}</span>
                  </div>
                  {card.type === "link" && (
                    <Icon
                      name="mdi:arrow-right"
                      class="w-4 h-4 text-accent-green/70 group-hover:translate-x-1 transition-transform duration-fast"
                    />
                  )}
                </Tag>
              );
            })}
          </div>
        </div>
      </aside>

      <div
        class="contact-form-wrap"
        data-reveal="fade-left"
        data-reveal-delay="50"
        data-reveal-duration="200"
        data-reveal-easing="ease-out"
      >
        <ContactForm class="contact-form-card" />
      </div>
    </div>
  </SectionShell>

  <SectionShell
    id="contact-faq"
    padding="normal"
    background="card"
    gradients={["center"]}
    patterns={["mesh"]}
    contentWidth="5xl"
    class="relative contact-faq-section section-divider"
  >
    <SectionHeader
      title={contactContent.faq.title}
      subtitle={contactContent.faq.description}
    />

    <div class="contact-faq-list">
      {contactContent.faq.items.map((item, index) => (
        <details
          class="contact-faq-item"
          open={index === 0}
          data-reveal="fade-up"
          data-reveal-delay={index * 35}
          data-reveal-duration="200"
          data-reveal-easing="ease-out"
        >
          <summary class="contact-faq-summary">
            <span>{item.question}</span>
            <span class="contact-faq-icon-wrap">
              <Icon name="mdi:minus" class="contact-faq-minus w-4 h-4" />
              <Icon name="mdi:plus" class="contact-faq-plus w-4 h-4" />
            </span>
          </summary>
          <div class="contact-faq-answer">
            <p>{item.answer}</p>
          </div>
        </details>
      ))}
    </div>

    <div class="contact-faq-footer">
      <p>If you already know the problem area, you can also browse the service library first.</p>
      <a href={createUrl("services")} class="contact-secondary-cta">
        View services
      </a>
    </div>
  </SectionShell>
</BaseLayout>
