---
import BaseLayout from "@/layouts/BaseLayout.astro";
import StructuredData from "@/components/common/StructuredData.astro";
import HeroSection from "@/components/sections/services/HeroSection.astro";
import ServicesStageSection from "@/components/sections/services/ServicesStageSection.astro";
import ImpactSection from "@/components/sections/services/ImpactSection.astro";
import ModelsSection from "@/components/sections/services/ModelsSection.astro";
import CtaSection from "@/components/sections/common/CtaSection.astro";
import { servicesContent } from "@/data/content";
import "@/styles/sections/hero.css";
import "@/styles/sections/services-sections.css";
import "@/styles/components/carousels.css";
import "@/styles/sections/carousel-sections.css";
import { createBreadcrumbSchema } from "@/lib/structuredData";

const breadcrumbSchema = createBreadcrumbSchema("/services", "Services");
const sections = [
  { Component: HeroSection, props: { content: servicesContent.hero } },
  {
    Component: ServicesStageSection,
    props: { content: servicesContent.serviceOfferings },
  },
  { Component: ImpactSection, props: { content: servicesContent.impact } },
  {
    Component: ModelsSection,
    props: { content: servicesContent.engagementModels },
  },
] as const;
const ctaProps = {
  id: "services-cta",
  title: servicesContent.cta.title,
  titleHighlight: ["Analytics Roadmap", "Reality"],
  description: servicesContent.cta.description,
  descriptionHighlight: servicesContent.cta.descriptionHighlight,
  ctaText: servicesContent.cta.ctaText,
  ctaHref: servicesContent.cta.ctaHref,
  variant: "standard" as const,
  background: "default" as const,
  maxWidth: "4xl" as const,
  class: "services-cta-section",
};
---

<BaseLayout
  title="Services | AUXO Data Labs"
  description="Analytics as a Service, built for impact. Discover our eight service offerings aligned to the analytics maturity curve, from Foundation Readiness to Autonomy Readiness Review."
>
  <StructuredData type="BreadcrumbList" data={breadcrumbSchema} />
  {sections.map(({ Component, props }) => <Component {...props} />)}
  <CtaSection {...ctaProps} />

  <script>
    import "@/scripts/pages/servicesCategoryTracking";
  </script>
</BaseLayout>
