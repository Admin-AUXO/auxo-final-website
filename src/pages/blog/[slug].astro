---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import StructuredData from "@/components/common/StructuredData.astro";
import SectionContainer from "@/components/layouts/SectionContainer.astro";
import BackgroundDecorations from "@/components/ui/BackgroundDecorations.astro";
import { Icon } from "astro-icon/components";
import { siteData } from "@/data/content";
import "@/styles/sections/blog-content.css";
import "@/styles/sections/blog-pages.css";
import {
  extractBlogHeadings,
  formatBlogDate,
  formatReadingTime,
  getBlogPostUrl,
  getReadingTimeMinutes,
  sortByPublishDate,
} from "@/lib/blog";

export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const allPosts = sortByPublishDate(await getCollection("blog"));
const { Content } = await entry.render();
const formattedPublishDate = formatBlogDate(entry.data.publishDate);
const readingTime = formatReadingTime(getReadingTimeMinutes(entry.body));
const articleSections = extractBlogHeadings(entry.body);
const currentIndex = allPosts.findIndex((post) => post.slug === entry.slug);
const newerPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
const olderPost =
  currentIndex >= 0 && currentIndex < allPosts.length - 1
    ? allPosts[currentIndex + 1]
    : null;
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.publishDate.toISOString(),
  dateModified: entry.data.publishDate.toISOString(),
  publisher: {
    "@type": "Organization",
    name: "AUXO Data Labs",
    logo: {
      "@type": "ImageObject",
      url: `${siteData.url}/logo.svg`,
    },
  },
};
---

<BaseLayout
  title={`${entry.data.title} | AUXO Insights`}
  description={entry.data.description}
>
  <StructuredData type="Article" data={articleSchema} />
  <SectionContainer
    id="blog-header"
    padding="lg"
    background="default"
    class="blog-page blog-article-page relative overflow-hidden pt-28 lg:pt-32 pb-12 lg:pb-14"
  >
    <div class="absolute inset-0 -z-10 pointer-events-none">
      <div class="absolute inset-0 bg-gradient-to-b from-theme-surface/94 via-theme-surface/76 to-theme-surface"></div>
      <div class="absolute inset-x-0 top-0 h-72 bg-gradient-to-b from-accent-green/10 to-transparent"></div>
    </div>
    <BackgroundDecorations gradients={["top"]} patterns={["grid"]} />

    <div class="grid-container relative z-10">
      <div class="col-span-full blog-article-hero">
        <a href="/blog" class="blog-back-link" data-reveal="fade-up">
          <Icon name="mdi:arrow-left" class="w-4 h-4 transition-transform duration-300" />
          Back to all insights
        </a>

        <div class="blog-article-hero__grid">
          <div class="blog-article-hero__rail" data-reveal="fade-up" data-reveal-delay="60">
            <p class="blog-kicker">AUXO Journal</p>

            <div class="blog-article-hero__meta">
              <div class="blog-article-hero__meta-row">
                <span class="blog-article-hero__meta-term">Published</span>
                <time
                  class="blog-article-hero__meta-value"
                  datetime={entry.data.publishDate.toISOString()}
                >
                  {formattedPublishDate}
                </time>
              </div>
              <div class="blog-article-hero__meta-row">
                <span class="blog-article-hero__meta-term">Read time</span>
                <span class="blog-article-hero__meta-value">{readingTime}</span>
              </div>
              <div class="blog-article-hero__meta-row">
                <span class="blog-article-hero__meta-term">Sections</span>
                <span class="blog-article-hero__meta-value">{articleSections.length || 1}</span>
              </div>
            </div>

            {articleSections.length > 0 && (
              <div class="blog-article-preview">
                <p class="blog-rail__label">In this article</p>
                {articleSections.slice(0, 4).map((section) => (
                  <a href={`#${section.id}`}>{section.text}</a>
                ))}
              </div>
            )}
          </div>

          <div class="blog-article-hero__main">
            <p class="blog-article-hero__tags" data-reveal="fade-up" data-reveal-delay="90">
              {entry.data.tags.join(" / ")}
            </p>

            <h1
              class="blog-article-hero__title"
              data-reveal="fade-up"
              data-reveal-delay="120"
            >
              {entry.data.title}
            </h1>

            <p
              class="blog-article-hero__dek"
              data-reveal="fade-up"
              data-reveal-delay="180"
            >
              {entry.data.description}
            </p>
          </div>
        </div>
      </div>
    </div>
  </SectionContainer>

  <SectionContainer
    id="blog-content"
    padding="normal"
    background="elevated"
    class="blog-page relative"
  >
    <div class="grid-container relative z-10">
      {articleSections.length > 0 && (
        <aside class="col-span-full lg:col-span-3 blog-article-sidebar">
          <div class="blog-article-sidebar__inner" data-reveal="fade-right">
            <div class="grid gap-3">
              <p class="blog-rail__label">Article map</p>
              <nav class="blog-article-toc" aria-label="Table of contents">
                {articleSections.map((section) => (
                  <a
                    href={`#${section.id}`}
                    class:list={{
                      "blog-article-toc__link": true,
                      "blog-article-toc__link--sub": section.level === 3,
                    }}
                  >
                    {section.text}
                  </a>
                ))}
              </nav>
            </div>

            <div class="blog-article-share">
              <p class="blog-rail__label">Share</p>
              <div class="blog-share-controls">
                <button id="share-twitter" class="blog-share-button" type="button">
                  <Icon name="mdi:twitter" class="w-4 h-4" />
                  Post
                </button>
                <button id="share-linkedin" class="blog-share-button" type="button">
                  <Icon name="mdi:linkedin" class="w-4 h-4" />
                  LinkedIn
                </button>
                <button id="share-copy" class="blog-share-button" type="button">
                  <Icon name="mdi:clipboard-text-outline" class="w-4 h-4" />
                  Copy link
                </button>
              </div>
            </div>
          </div>
        </aside>
      )}

      <div
        class:list={[
          "col-span-full",
          articleSections.length > 0
            ? "lg:col-span-8 lg:col-start-5"
            : "lg:col-span-8 lg:col-start-3",
        ]}
      >
        <article class="blog-content blog-article-shell" data-reveal="fade-up">
          <Content />
        </article>

        <div class="blog-article-afterword">
          Need help turning the argument into an actual operating plan? <a href="/contact">Talk to AUXO</a>.
        </div>

        <div class="blog-article-nav">
          {newerPost && (
            <a href={getBlogPostUrl(newerPost.slug)} class="blog-article-nav__link">
              <div class="blog-article-nav__copy">
                <span class="blog-article-nav__eyebrow">Newer insight</span>
                <span class="blog-article-nav__title">{newerPost.data.title}</span>
              </div>
              <Icon name="mdi:arrow-right" class="w-4 h-4" />
            </a>
          )}

          {olderPost && (
            <a href={getBlogPostUrl(olderPost.slug)} class="blog-article-nav__link">
              <div class="blog-article-nav__copy">
                <span class="blog-article-nav__eyebrow">Older insight</span>
                <span class="blog-article-nav__title">{olderPost.data.title}</span>
              </div>
              <Icon name="mdi:arrow-right" class="w-4 h-4" />
            </a>
          )}

          {!newerPost && !olderPost && (
            <a href="/blog" class="blog-article-nav__link">
              <div class="blog-article-nav__copy">
                <span class="blog-article-nav__eyebrow">Archive</span>
                <span class="blog-article-nav__title">Back to all insights</span>
              </div>
              <Icon name="mdi:arrow-right" class="w-4 h-4" />
            </a>
          )}
        </div>
      </div>
    </div>
  </SectionContainer>
</BaseLayout>

<script>
  import "@/scripts/pages/blogShare";
</script>
