---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import StructuredData from "@/components/common/StructuredData.astro";
import SectionContainer from "@/components/layouts/SectionContainer.astro";
import BackgroundDecorations from "@/components/ui/BackgroundDecorations.astro";
import { Icon } from "astro-icon/components";
import { siteData } from "@/data/content";
import "@/styles/sections/blog-content.css";
import "@/styles/sections/blog-pages.css";
import {
  formatBlogDate,
  formatReadingTime,
  getBlogPostUrl,
  getReadingTimeMinutes,
  sortByPublishDate,
} from "@/lib/blog";

export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const allPosts = sortByPublishDate(await getCollection("blog"));
const { Content } = await entry.render();
const formattedPublishDate = formatBlogDate(entry.data.publishDate);
const readingTime = formatReadingTime(getReadingTimeMinutes(entry.body));
const currentIndex = allPosts.findIndex((post) => post.slug === entry.slug);
const newerPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
const olderPost =
  currentIndex >= 0 && currentIndex < allPosts.length - 1
    ? allPosts[currentIndex + 1]
    : null;
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.publishDate.toISOString(),
  dateModified: entry.data.publishDate.toISOString(),
  publisher: {
    "@type": "Organization",
    name: "AUXO Data Labs",
    logo: {
      "@type": "ImageObject",
      url: `${siteData.url}/logo.svg`,
    },
  },
  image: entry.data.heroImage ? `${siteData.url}${entry.data.heroImage}` : undefined,
};
---

<BaseLayout
  title={`${entry.data.title} | AUXO Insights`}
  description={entry.data.description}
>
  <StructuredData type="Article" data={articleSchema} />

  <!-- ═══════════════════════════════════════════════════
       HERO IMAGE — full width, above everything
  ═══════════════════════════════════════════════════ -->
  {entry.data.heroImage && (
    <div class="blog-article-full-image">
      <img
        src={entry.data.heroImage}
        alt={`Visual for: ${entry.data.title}`}
        width="1536"
        height="860"
        loading="eager"
      />
    </div>
  )}

  <!-- ═══════════════════════════════════════════════════
       HEADER — centered, clean
  ═══════════════════════════════════════════════════ -->
  <SectionContainer
    id="blog-header"
    padding="lg"
    background="default"
    class="blog-page blog-article-page relative overflow-hidden pt-16 pb-10"
  >
    <div class="absolute inset-0 -z-10 pointer-events-none">
      <div class="absolute inset-0 bg-gradient-to-b from-theme-surface/96 via-theme-surface/80 to-theme-surface"></div>
    </div>
    <BackgroundDecorations gradients={["top"]} patterns={["grid"]} />

    <div class="grid-container relative z-10">
      <div class="col-span-full">

        <!-- Back link -->
        <a href="/blog" class="blog-back-link" data-reveal="fade-up">
          <Icon name="mdi:arrow-left" class="w-4 h-4" />
          All insights
        </a>

        <!-- Meta strip: date / read time / tags -->
        <div class="blog-article-meta-strip" data-reveal="fade-up" data-reveal-delay="60">
          <time
            class="blog-article-meta-item"
            datetime={entry.data.publishDate.toISOString()}
          >
            {formattedPublishDate}
          </time>
          <span class="blog-article-meta-dot" aria-hidden="true">·</span>
          <span class="blog-article-meta-item">{readingTime}</span>
          <span class="blog-article-meta-dot" aria-hidden="true">·</span>
          <span class="blog-article-meta-item">{entry.data.tags[0]}</span>
        </div>

        <!-- Title -->
        <h1
          class="blog-article-display-title"
          data-reveal="fade-up"
          data-reveal-delay="120"
        >
          {entry.data.title}
        </h1>

        <!-- Dek -->
        <p
          class="blog-article-dek"
          data-reveal="fade-up"
          data-reveal-delay="180"
        >
          {entry.data.description}
        </p>

        <!-- Share strip -->
        <div class="blog-article-share-strip" data-reveal="fade-up" data-reveal-delay="220">
          <span class="blog-share-label">Share</span>
          <button id="share-twitter" class="blog-share-btn" type="button">
            <Icon name="mdi:twitter" class="w-4 h-4" />
            Post
          </button>
          <button id="share-linkedin" class="blog-share-btn" type="button">
            <Icon name="mdi:linkedin" class="w-4 h-4" />
            LinkedIn
          </button>
          <button id="share-copy" class="blog-share-btn" type="button">
            <Icon name="mdi:clipboard-text-outline" class="w-4 h-4" />
            Copy link
          </button>
        </div>

      </div>
    </div>
  </SectionContainer>

  <!-- ═══════════════════════════════════════════════════
       BODY — single centered column
  ═══════════════════════════════════════════════════ -->
  <SectionContainer
    id="blog-content"
    padding="normal"
    background="elevated"
    class="blog-page"
  >
    <div class="grid-container relative z-10">
      <div class="col-span-full">

        <article class="blog-article-body" data-reveal="fade-up">
          <Content />

          <div class="blog-article-afterword">
            <div class="blog-article-afterword__text">
              <p>Ready to work backward from the decisions your organization actually needs to make?</p>
            </div>
            <a href="/contact" class="blog-article-afterword__cta">
              Talk to AUXO
              <Icon name="mdi:arrow-right" class="w-4 h-4" />
            </a>
          </div>
        </article>

        <!-- Prev / Next navigation -->
        <nav class="blog-article-nav" aria-label="Article navigation">
          {newerPost && (
            <a href={getBlogPostUrl(newerPost.slug)} class="blog-article-nav__item blog-article-nav__item--prev">
              <span class="blog-article-nav__dir">
                <Icon name="mdi:arrow-left" class="w-4 h-4" />
                Newer
              </span>
              <span class="blog-article-nav__title">{newerPost.data.title}</span>
            </a>
          )}

          {olderPost && (
            <a href={getBlogPostUrl(olderPost.slug)} class="blog-article-nav__item blog-article-nav__item--next">
              <span class="blog-article-nav__dir">
                Older
                <Icon name="mdi:arrow-right" class="w-4 h-4" />
              </span>
              <span class="blog-article-nav__title">{olderPost.data.title}</span>
            </a>
          )}

          {!newerPost && !olderPost && (
            <a href="/blog" class="blog-article-nav__item blog-article-nav__item--back">
              <span class="blog-article-nav__dir">
                <Icon name="mdi:arrow-left" class="w-4 h-4" />
                All insights
              </span>
              <span class="blog-article-nav__title">Back to the journal</span>
            </a>
          )}
        </nav>

      </div>
    </div>
  </SectionContainer>
</BaseLayout>

<script>
  import "@/scripts/pages/blogShare";
</script>
