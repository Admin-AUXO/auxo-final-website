---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import SectionContainer from "@/components/layouts/SectionContainer.astro";
import BackgroundDecorations from "@/components/ui/BackgroundDecorations.astro";
import { Icon } from "astro-icon/components";
import { createUrl } from "@/utils/url";
import "@/styles/sections/blog-pages.css";
import {
  formatBlogDate,
  formatReadingTime,
  getBlogPostUrl,
  getReadingTimeMinutes,
  sortByPublishDate,
} from "@/lib/blog";

const allPosts = sortByPublishDate(await getCollection("blog"));
const featuredPost = allPosts[0] ?? null;
const archivePosts = allPosts.slice(1);
const uniqueTags = [...new Set(allPosts.flatMap((post) => post.data.tags))];
const archiveDateFormatter = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "2-digit",
});
const archiveYearFormatter = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
});
---

<BaseLayout
  title="Insights & Blog | AUXO Data Labs"
  description="Editorial analysis, strategic briefings, and applied data thinking from AUXO Data Labs."
>
  <!-- ═══════════════════════════════════════════════════
       MASTHEAD
  ═══════════════════════════════════════════════════ -->
  <SectionContainer
    id="blog-hero"
    padding="lg"
    background="default"
    class="blog-page blog-index-page relative overflow-hidden pt-28 lg:pt-32 pb-10 lg:pb-12"
  >
    <div class="absolute inset-0 -z-10 pointer-events-none">
      <div class="absolute inset-0 bg-gradient-to-b from-theme-surface/92 via-theme-surface/70 to-theme-surface"></div>
      <div class="absolute inset-x-0 top-0 h-72 bg-gradient-to-b from-accent-green/10 to-transparent"></div>
    </div>
    <BackgroundDecorations gradients={["hero"]} patterns={["grid"]} />

    <div class="grid-container relative z-10">
      <div class="col-span-full">
        <div class="blog-masthead blog-masthead--centered" data-reveal="fade-up">
          <p class="blog-kicker">AUXO Journal</p>
          <h1 class="blog-masthead__title" data-reveal="fade-up" data-reveal-delay="60">
            Signals for teams that need <span>clearer decisions</span>, not more dashboard theater.
          </h1>
          <p class="blog-masthead__dek" data-reveal="fade-up" data-reveal-delay="120">
            Strategic notes, execution patterns, and analytical field reports from AUXO Data Labs.
            The point is usable clarity. Anything softer is decoration.
          </p>
        </div>
      </div>
    </div>
  </SectionContainer>

  <!-- ═══════════════════════════════════════════════════
       FEATURED POST
  ═══════════════════════════════════════════════════ -->
  {featuredPost && (
    <SectionContainer
      id="blog-featured"
      padding="normal"
      background="elevated"
      class="blog-page"
    >
      <div class="grid-container relative z-10">
        <div class="col-span-full">

          <!-- Section label -->
          <div class="blog-section-header" data-reveal="fade-up">
            <span class="blog-section-label">Lead story</span>
          </div>

          <!-- Featured card -->
          <div data-reveal="fade-up" data-reveal-delay="60">
            <a href={getBlogPostUrl(featuredPost.slug)} class="blog-featured-card group">
              {featuredPost.data.heroImage && (
                <div class="blog-featured-card__image">
                  <img
                    src={featuredPost.data.heroImage}
                    alt={featuredPost.data.title}
                    width="960"
                    height="540"
                    loading="eager"
                  />
                </div>
              )}
              <div class="blog-featured-card__body">
                <p class="blog-featured-card__meta">
                  {formatBlogDate(featuredPost.data.publishDate)}
                  <span aria-hidden="true"> &bull; </span>
                  {formatReadingTime(getReadingTimeMinutes(featuredPost.body))}
                  <span aria-hidden="true"> &bull; </span>
                  {featuredPost.data.tags.slice(0, 2).join(" / ")}
                </p>
                <h2 class="blog-featured-card__title">{featuredPost.data.title}</h2>
                <p class="blog-featured-card__description">{featuredPost.data.description}</p>
                <span class="blog-featured-card__cta">
                  Read article
                  <Icon name="mdi:arrow-right" class="w-4 h-4 transition-transform duration-300" />
                </span>
              </div>
            </a>
          </div>

          <!-- Tag filter strip -->
          {uniqueTags.length > 0 && (
            <div class="blog-tag-strip" data-reveal="fade-up" data-reveal-delay="120">
              <span class="blog-tag-strip__label">Topics</span>
              <div class="blog-tag-list">
                {uniqueTags.map((tag) => (
                  <span class="blog-tag">{tag}</span>
                ))}
              </div>
            </div>
          )}

        </div>
      </div>
    </SectionContainer>
  )}

  <!-- ═══════════════════════════════════════════════════
       ARCHIVE
  ═══════════════════════════════════════════════════ -->
  {archivePosts.length > 0 && (
    <SectionContainer
      id="blog-archive"
      padding="normal"
      background="card"
      class="blog-page"
    >
      <div class="grid-container relative z-10">
        <div class="col-span-full">

          <!-- Section header -->
          <div class="blog-section-header" data-reveal="fade-up">
            <span class="blog-section-label">Archive</span>
            <p class="blog-section-sub">
              {archivePosts.length} {archivePosts.length === 1 ? "post" : "posts"} &mdash; newest first
            </p>
          </div>

          <!-- Archive list -->
          <div class="blog-archive-list" data-reveal="fade-up" data-reveal-delay="60">
            {archivePosts.map((post) => (
              <a
                href={getBlogPostUrl(post.slug)}
                class="blog-archive-item group"
              >
                <!-- Date column -->
                <div class="blog-archive-item__date">
                  <span class="blog-archive-item__day">
                    {archiveDateFormatter.format(post.data.publishDate)}
                  </span>
                  <span class="blog-archive-item__year">
                    {archiveYearFormatter.format(post.data.publishDate)}
                  </span>
                </div>

                <!-- Content -->
                <div class="blog-archive-item__body">
                  <p class="blog-archive-item__tags">{post.data.tags.join(" / ")}</p>
                  <h3 class="blog-archive-item__title">{post.data.title}</h3>
                  <p class="blog-archive-item__desc">{post.data.description}</p>
                </div>

                <!-- Meta column -->
                <div class="blog-archive-item__meta">
                  <span class="blog-archive-item__readtime">
                    {formatReadingTime(getReadingTimeMinutes(post.body))}
                  </span>
                  <span class="blog-archive-item__arrow">
                    <Icon name="mdi:arrow-right" class="w-4 h-4 transition-transform duration-300" />
                  </span>
                </div>
              </a>
            ))}
          </div>

          <!-- Editorial note + nav -->
          <div class="blog-archive-footer" data-reveal="fade-up">
            <div class="blog-archive-footer__links">
              <a href={createUrl("services")} class="blog-inline-link">
                Explore services
                <Icon name="mdi:arrow-right" class="w-4 h-4" />
              </a>
              <a href={createUrl("contact")} class="blog-inline-link">
                Talk to AUXO
                <Icon name="mdi:arrow-right" class="w-4 h-4" />
              </a>
            </div>
            <p class="blog-archive-footer__note">
              Every post is written at the analysis-desk level &mdash; specific observations, named failure modes, credible closes.
            </p>
          </div>

        </div>
      </div>
    </SectionContainer>
  )}
</BaseLayout>
