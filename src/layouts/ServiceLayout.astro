---
import BaseLayout from "@/layouts/BaseLayout.astro";
import "@/styles/sections/hero.css";
import "@/styles/sections/services-individual.css";
import "@/styles/components/carousels.css";
import "@/styles/sections/carousel-sections.css";

export interface Props {
  title: string;
  description: string;
  serviceName: string;
}

const { title, description, serviceName } = Astro.props;
---

<BaseLayout title={`${serviceName} | AUXO Data Labs`} description={description}>
  <div data-service-name={serviceName} class="relative">
    <slot name="hero" />

    <slot name="overview" />
    <slot name="benefits" />
    <slot name="process" />
    <slot name="outcomes" />
    <slot name="cta" />
  </div>

  <script>
    import {
      setupServicePageAnimations,
      cleanupServicePageAnimations,
    } from "@/scripts/sections/services/servicePage";

    const servicePath = window.location.pathname;

    const runSetup = () => {
      if (window.location.pathname === servicePath) {
        setupServicePageAnimations();
      }
    };

    runSetup();
    document.addEventListener("astro:page-load", runSetup, { once: true });
    document.addEventListener("astro:before-preparation", cleanupServicePageAnimations, { once: true });
  </script>
</BaseLayout>
