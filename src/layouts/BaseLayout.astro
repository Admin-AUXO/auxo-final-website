---
import { siteData } from "@/data/content";

import Navigation from "@/components/common/Navigation.astro";
import Footer from "@/components/common/Footer.astro";
import MetaTags from "@/components/common/MetaTags.astro";
import StructuredData from "@/components/common/StructuredData.astro";
import CookieConsent from "@/components/common/CookieConsent.astro";

import "@/styles/base.css";
import "@/styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  enableCalendarWidgets?: boolean;
  enableCookieConsent?: boolean;
  enableTabEngagement?: boolean;
}

const {
  title,
  description,
  enableCalendarWidgets: enableCalendarWidgetsProp,
  enableCookieConsent: enableCookieConsentProp,
  enableTabEngagement: enableTabEngagementProp,
} = Astro.props;

const pageTitle = title || siteData.name;
const pageDescription = description || siteData.description;
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const isLegalRoute = pathname.startsWith("/legal");
const isBlogRoute = pathname === "/blog" || pathname.startsWith("/blog/");
const isUtilityRoute = pathname === "/offline" || pathname === "/404";
const areOptionalWidgetsEnabledByDefault = !(isLegalRoute || isBlogRoute || isUtilityRoute);

const enableCalendarWidgets =
  enableCalendarWidgetsProp ?? areOptionalWidgetsEnabledByDefault;
const enableCookieConsent =
  enableCookieConsentProp ?? areOptionalWidgetsEnabledByDefault;
const enableTabEngagement =
  enableTabEngagementProp ?? areOptionalWidgetsEnabledByDefault;

const organizationSchema = {
  name: siteData.name,
  alternateName: "AUXO Data Labs",
  url: siteData.url,
  logo: `${siteData.url}/logo.svg`,
  description: siteData.description,
  email: siteData.email,
  foundingDate: String(siteData.founded),
  address: {
    "@type": "PostalAddress",
    streetAddress: siteData.address.street,
    addressLocality: siteData.address.city,
    addressCountry: siteData.address.country,
  },
  sameAs: [siteData.social.linkedin, siteData.social.twitter],
};

const websiteSchema = {
  name: siteData.name,
  url: siteData.url,
  description: siteData.description,
  inLanguage: "en-US",
};

const webPageSchema = {
  name: pageTitle,
  description: pageDescription,
  url: `${siteData.url}${Astro.url.pathname}`,
  inLanguage: "en-US",
  isPartOf: {
    "@type": "WebSite",
    name: siteData.name,
    url: siteData.url,
  },
  about: {
    "@type": "Organization",
    name: siteData.name,
  },
  breadcrumb: {
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: siteData.url,
      },
      ...(Astro.url.pathname !== "/"
        ? [
            {
              "@type": "ListItem",
              position: 2,
              name: pageTitle,
              item: `${siteData.url}${Astro.url.pathname}`,
            },
          ]
        : []),
    ],
  },
};
---

<!doctype html>
<html lang="en" class="scrollbar-hide">
  <head>
    <MetaTags
      title={pageTitle}
      description={pageDescription}
      siteName={siteData.name}
      siteUrl={siteData.url}
      themeColor={siteData.themeColor}
    />
    <StructuredData type="Organization" data={organizationSchema} />
    <StructuredData type="WebSite" data={websiteSchema} />
    <StructuredData type="WebPage" data={webPageSchema} />
    <script is:inline>
      (function () {
        const root = document.documentElement;
        const stored = localStorage.getItem("theme");
        const BREAKPOINTS_MD = 768;
        const isMobile =
          /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(
            navigator.userAgent,
          ) || window.innerWidth < BREAKPOINTS_MD;

        let theme;
        if (stored) {
          theme = stored;
        } else if (isMobile) {
          theme = "dark";
        } else {
          theme = window.matchMedia("(prefers-color-scheme: light)").matches
            ? "light"
            : "dark";
        }

        root.classList.remove("dark", "light");
        root.classList.add(theme);
        root.style.colorScheme = theme;
        root.classList.add("loading");
      })();
    </script>
  </head>
  <body
    class="min-h-screen bg-primary transition-colors duration-normal scrollbar-hide"
    data-enable-calendar-widgets={enableCalendarWidgets ? "true" : "false"}
    data-enable-tab-engagement={enableTabEngagement ? "true" : "false"}
  >
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-N6547BGW"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >

    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[2147483648] focus:px-4 focus:py-2 focus:bg-accent-green focus:text-text-on-accent focus:rounded-md focus:shadow-lg focus:font-medium transition-all duration-fast"
    >
      Skip to main content
    </a>

    <div
      id="scroll-progress-bar"
      class="fixed top-0 left-0 right-0 w-full bg-transparent pointer-events-none h-[var(--scroll-progress-height-mobile)] sm:h-[var(--scroll-progress-height)]"
      aria-hidden="true"
    >
      <div class="scroll-progress-bar-fill"></div>
    </div>
    <Navigation />
    <main
      id="main-content"
      class="relative z-content"
      style="padding-top: var(--nav-current-height); min-height: calc(100vh - var(--nav-current-height));"
    >
      <slot />
    </main>
    <Footer />
    {enableCookieConsent && <CookieConsent />}

    <script>
      import "@/scripts/core/layoutRuntime";
    </script>
  </body>
</html>
