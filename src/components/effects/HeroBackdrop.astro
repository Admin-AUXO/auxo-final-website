---
import BackgroundDecorations from "@/components/ui/BackgroundDecorations.astro";
import ParticleBackground from "@/components/effects/ParticleBackground.astro";

type ParticleMode =
  | "galaxy"
  | "network"
  | "flow"
  | "data"
  | "waves"
  | "logic"
  | "sys"
  | "ai"
  | "expand"
  | "articles"
  | "about";

interface Props {
  mode: ParticleMode;
  overlayClass?: string;
  topOverlayClass?: string;
  showDecorations?: boolean;
  showAccentLines?: boolean;
}

const {
  mode,
  overlayClass = "",
  topOverlayClass = "",
  showDecorations = false,
  showAccentLines = false,
} = Astro.props;
---

<div class="absolute inset-0 z-0 overflow-hidden pointer-events-none layout-shift-fix">
  <ParticleBackground mode={mode} />

  {overlayClass && <div class={`absolute inset-0 ${overlayClass}`}></div>}
  {topOverlayClass && (
    <div class={`absolute top-0 inset-x-0 ${topOverlayClass}`}></div>
  )}
</div>

{showDecorations && <BackgroundDecorations gradients={["hero"]} />}

{
  showAccentLines && (
    <div
      class="section-hero-accent-lines absolute inset-0 pointer-events-none z-0 overflow-hidden"
    >
      <div
        class="section-hero-line section-hero-line-1 absolute top-1/4 left-0 w-full h-px bg-gradient-to-r from-transparent via-accent-green/20 to-transparent"
        data-reveal="fade-right"
        data-reveal-delay="0"
        data-reveal-duration="200"
        data-reveal-easing="ease-out"
      >
      </div>
      <div
        class="section-hero-line section-hero-line-2 absolute top-3/4 right-0 w-full h-px bg-gradient-to-l from-transparent via-accent-green/15 to-transparent"
        data-reveal="fade-left"
        data-reveal-delay="50"
        data-reveal-duration="200"
        data-reveal-easing="ease-out"
      >
      </div>
    </div>
  )
}
