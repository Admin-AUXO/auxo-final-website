---
import { siteData } from "@/data/content";
import { Icon } from "astro-icon/components";

export interface Props {
  email?: string;
  title?: string;
  intro?: string;
}

const {
  email = siteData.privacyEmail,
  title = "Contact Us",
  intro = "If you have any questions, please contact us at:",
} = Astro.props;

const contactItems = [
  {
    icon: "mdi:email-outline",
    label: "Email",
    href: `mailto:${email}`,
    value: email,
  },
  {
    icon: "mdi:map-marker-outline",
    label: "Address",
    iconClass: "mt-0.5",
    value: `${siteData.address.street}, ${siteData.address.city}, ${siteData.address.country}`,
  },
];
---

<div class="legal-contact">
  <div class="legal-contact__header">
    <h2>{title}</h2>
    <p class="mb-0">{intro}</p>
  </div>
  <div class="space-y-3">
    {contactItems.map(({ icon, label, iconClass = "", href, value }) => (
      <div class="legal-contact__row">
        <Icon
          name={icon}
          class={`w-5 h-5 text-accent-green flex-shrink-0 ${iconClass}`}
        />
        <div>
          <strong class="text-theme-primary block mb-1">{label}</strong>
          {
            href ? (
              <a
                href={href}
                class="text-accent-green hover:opacity-80 transition-opacity font-semibold"
              >
                {value}
              </a>
            ) : (
              <p class="text-theme-secondary m-0">{value}</p>
            )
          }
        </div>
      </div>
    ))}
  </div>
</div>
