---
import { getBaseUrl } from "@/utils/url";

interface Props {
  size?: "sm" | "md" | "lg";
  showText?: boolean;
  href?: string;
  class?: string;
}

const {
  size = "md",
  showText = true,
  href,
  class: className = "",
} = Astro.props;

const finalHref = href || getBaseUrl();

const sizeClasses = {
  sm: "h-9 w-9 sm:h-10 sm:w-10",
  md: "h-10 w-10 sm:h-11 sm:w-11 lg:h-12 lg:w-12",
  lg: "h-14 w-14 lg:h-16 lg:w-16",
};

const logoSize = sizeClasses[size];
const logoCells = [
  { x: 0, y: 0, label: "A", textX: 9, textY: 14 },
  { x: 22, y: 0, label: "U", textX: 31, textY: 14 },
  { x: 0, y: 22, label: "X", textX: 9, textY: 36 },
  { x: 22, y: 22, label: "O", textX: 31, textY: 36 },
];
---

<a
  href={finalHref}
  class={`flex items-center space-x-2.5 sm:space-x-3 group relative touch-manipulation flex-shrink-0 z-content pointer-events-auto ${className}`}
  aria-label="AUXO Data Labs Home"
  data-nav-home
  data-logo-root
>
  <div class="relative">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 40 40"
      fill="none"
      class={`${logoSize} transition-transform duration-normal group-hover:scale-110 group-hover:rotate-3`}
      aria-label="AUXO Data Labs Logo"
    >
      {logoCells.map(({ x, y, label, textX, textY }) => (
        <>
          <rect
            x={x}
            y={y}
            width="18"
            height="18"
            fill="var(--accent-green)"
            class="transition-colors duration-normal"
          ></rect>
          <text
            x={textX}
            y={textY}
            text-anchor="middle"
            font-family="var(--font-brand)"
            font-weight="900"
            font-size="13"
            fill="var(--logo-text-color)"
            class="transition-colors duration-normal"
          >
            {label}
          </text>
        </>
      ))}
    </svg>
    <div
      class="absolute inset-0 bg-accent-green/20 rounded-full blur-lg opacity-0 group-hover:opacity-100 transition-opacity duration-normal"
    >
    </div>
  </div>
  {
    showText && (
      <>
        <div class="flex flex-col hidden lg:flex items-center pointer-events-none">
          <div class="logo-text-container">
            <span class="logo-tagline">Data Labs</span>
            <span class="logo-subtitle">Look Beyond Data</span>
          </div>
        </div>

        <script is:inline>
          (() => {
            const root = document.currentScript?.closest("[data-logo-root]");
            if (!(root instanceof HTMLElement)) return;

            const tagline = root.querySelector(".logo-tagline");
            const subtitle = root.querySelector(".logo-subtitle");
            if (!(tagline instanceof HTMLElement) || !(subtitle instanceof HTMLElement)) {
              return;
            }

            let animationFrameId = 0;

            const updateWidth = () => {
              subtitle.style.letterSpacing = "";

              const taglineWidth = tagline.offsetWidth;
              const subtitleWidth = subtitle.scrollWidth;
              const textLength = subtitle.textContent?.length || 0;

              if (
                taglineWidth <= 0 ||
                subtitleWidth <= 0 ||
                textLength <= 1 ||
                subtitleWidth >= taglineWidth
              ) {
                return;
              }

              const currentLetterSpacing =
                parseFloat(getComputedStyle(subtitle).letterSpacing) || 0;
              const widthDiff = taglineWidth - subtitleWidth;
              const letterSpacingPerChar = widthDiff / (textLength - 1);

              cancelAnimationFrame(animationFrameId);
              animationFrameId = requestAnimationFrame(() => {
                subtitle.style.letterSpacing = `${currentLetterSpacing + letterSpacingPerChar}px`;
              });
            };

            const init = () => {
              setTimeout(updateWidth, 0);
              setTimeout(updateWidth, 100);
              setTimeout(updateWidth, 300);
            };

            init();
            window.addEventListener("resize", updateWidth, { passive: true });
            document.addEventListener(
              "astro:before-swap",
              () => window.removeEventListener("resize", updateWidth),
              { once: true },
            );

            if (document.readyState === "loading") {
              document.addEventListener("DOMContentLoaded", init, { once: true });
            }
          })();
        </script>
      </>
    )
  }
</a>
