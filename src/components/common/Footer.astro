---
import { Icon } from "astro-icon/components";
import Logo from "./Logo.astro";
import { footerContent } from "@/data/content/footer-data";
import { siteData } from "@/data/content/siteConfig-data";
import { getBaseUrl, createUrl } from "@/utils/url";

const base = getBaseUrl();
const currentYear = new Date().getFullYear();
const privacyUrl = createUrl("legal/privacy-policy");

const { sections } = footerContent;
const footerSections = sections;
const iconContainerClass =
  "w-12 h-12 bg-accent-green/15 rounded-xl flex items-center justify-center flex-shrink-0";
const socialLinks = [
  {
    href: siteData.social.linkedin,
    icon: "mdi:linkedin",
    label: "Follow AUXO Data Labs on LinkedIn",
  },
  {
    href: siteData.social.twitter,
    icon: "mdi:twitter",
    label: "Follow AUXO Data Labs on Twitter",
  },
];
const socialSizeConfig = {
  sm: {
    container: "flex gap-2.5 justify-center",
    button:
      "w-10 h-10 min-w-[var(--button-height-sm)] min-h-[var(--button-height-sm)] rounded-lg hover:scale-110",
    icon: "w-5 h-5",
    title: "text-center mb-3",
  },
  lg: {
    container: "flex gap-4",
    button:
      "w-14 h-14 lg:w-16 lg:h-16 lg:min-w-[var(--decorative-size-md)] lg:min-h-[var(--decorative-size-md)] rounded-xl hover:-translate-y-1 active:translate-y-0 touch-target-large group",
    icon:
      "w-7 h-7 lg:w-8 lg:h-8 group-hover:scale-110 transition-transform",
    title: "mb-4",
  },
};
---

<footer
  class="bg-theme-card border-t-2 border-theme relative z-content transition-colors duration-normal"
>
  <div class="grid-container py-4 sm:py-8 lg:py-10">
    <div class="col-span-full sm:hidden space-y-2">
      <nav class="space-y-2">
        {
          footerSections.map((section) => (
            <details class="group footer-accordion rounded-lg border border-transparent hover:border-accent-green/10 transition-colors">
              <summary class="flex items-center justify-between py-3 px-3 cursor-pointer list-none touch-manipulation select-none">
                <span class="flex items-center gap-2.5 pointer-events-none">
                  <span class="w-8 h-8 rounded-lg bg-accent-green/10 flex items-center justify-center flex-shrink-0">
                    <Icon
                      name={section.icon}
                      class="w-4 h-4 text-accent-green"
                    />
                  </span>
                  <span class="text-sm font-semibold text-theme-primary font-display">
                    {section.title}
                  </span>
                </span>
                <span class="w-6 h-6 rounded-full bg-accent-green/10 flex items-center justify-center flex-shrink-0 pointer-events-none transition-colors group-open:bg-accent-green/20">
                  <Icon
                    name="mdi:chevron-down"
                    class="w-4 h-4 text-accent-green transition-transform duration-200 group-open:rotate-180"
                  />
                </span>
              </summary>
              <ul class="pb-3 pl-[3.25rem] pr-3 space-y-1">
                {section.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="text-sm text-theme-secondary hover:text-accent-green transition-colors py-2 flex items-center font-body"
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          ))
        }
      </nav>

      <div class="pt-3">
        <p
          class={`text-xs font-semibold text-theme-secondary uppercase tracking-wider ${socialSizeConfig.sm.title} font-body`}
        >
          Follow Us
        </p>
        <div class={socialSizeConfig.sm.container}>
          {
            socialLinks.map((social) => (
              <a
                href={social.href}
                class={`${socialSizeConfig.sm.button} bg-accent-green/10 hover:bg-accent-green hover:text-on-accent border border-accent-green/30 hover:border-accent-green hover:shadow-lg hover:shadow-accent-green/30 active:scale-95 flex items-center justify-center text-accent-green transition-all duration-fast focus:outline-none focus:ring-[3px] focus:ring-accent-green/50`}
                aria-label={social.label}
                target="_blank"
                rel="noopener noreferrer"
              >
                <Icon
                  name={social.icon}
                  class={socialSizeConfig.sm.icon}
                />
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <div
      class="hidden sm:grid sm:grid-cols-12 lg:grid-cols-12 gap-6 lg:gap-10 col-span-full"
    >
      <section class="sm:col-span-12 lg:col-span-5 space-y-4 sm:space-y-6">
        <Logo size="lg" showText={true} href={base} class="items-start" />

        <div class="space-y-4">
          <a
            href={`mailto:${siteData.email}?subject=Inquiry from AUXO Website`}
            class="flex items-center gap-3 group"
          >
            <div
              class={`${iconContainerClass} group-hover:bg-accent-green/25 transition-colors`}
            >
              <Icon name="mdi:email-outline" class="w-6 h-6 text-accent-green" />
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-base font-semibold text-theme-primary break-all group-hover:text-accent-green transition-colors font-body">
                {siteData.email}
              </div>
              <div class="flex items-center gap-2 mt-1">
                <Icon
                  name="mdi:clock-outline"
                  class="w-3.5 h-3.5 text-theme-secondary"
                />
                <span class="text-xs text-theme-secondary font-body">
                  Response within
                  <span class="font-medium text-accent-green">24 hours</span>
                </span>
              </div>
            </div>
          </a>

          <div class="flex items-center gap-3 text-theme-secondary">
            <div class={iconContainerClass}>
              <Icon
                name="mdi:map-marker-outline"
                class="w-6 h-6 text-accent-green"
              />
            </div>
            <span class="text-base font-body">
              {siteData.address.city}, {siteData.address.country}
            </span>
          </div>
        </div>

        <div class="pt-2">
          <p
            class={`text-xs font-semibold text-theme-secondary uppercase tracking-wider ${socialSizeConfig.lg.title} font-body`}
          >
            Follow Us
          </p>
          <div class={socialSizeConfig.lg.container}>
            {
              socialLinks.map((social) => (
                <a
                  href={social.href}
                  class={`${socialSizeConfig.lg.button} bg-accent-green/10 hover:bg-accent-green hover:text-on-accent border border-accent-green/30 hover:border-accent-green hover:shadow-lg hover:shadow-accent-green/30 active:scale-95 flex items-center justify-center text-accent-green transition-all duration-fast focus:outline-none focus:ring-[3px] focus:ring-accent-green/50`}
                  aria-label={social.label}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <Icon
                    name={social.icon}
                    class={socialSizeConfig.lg.icon}
                  />
                </a>
              ))
            }
          </div>
        </div>
      </section>

      <section
        class="sm:col-span-12 lg:col-span-7 mt-0 mb-0 sm:mt-0 sm:mb-auto"
      >
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
          {
            footerSections.map((section) => (
              <div class="space-y-3 sm:space-y-4">
                <h4 class="text-sm font-extrabold tracking-wide text-theme-primary uppercase transition-colors flex items-center gap-2 mb-4 font-display">
                  <Icon name={section.icon} class="w-5 h-5 text-accent-green" />
                  {section.title}
                </h4>
                <nav>
                  <ul class="space-y-2 sm:space-y-2.5">
                    {section.links.map((link) => (
                      <li>
                        <a
                          href={link.href}
                          class="text-sm text-theme-secondary hover:text-accent-green transition-colors duration-fast inline-flex items-center gap-2 group min-h-[var(--touch-target-min)] active:text-accent-green font-medium font-body"
                        >
                          <span>{link.label}</span>
                          <Icon
                            name="mdi:arrow-right"
                            class="w-4 h-4 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-fast"
                          />
                        </a>
                      </li>
                    ))}
                  </ul>
                </nav>
              </div>
            ))
          }
        </div>
      </section>
    </div>
  </div>

  <div
    class="col-span-full pt-1 sm:border-t sm:border-theme sm:pt-5 mt-1 sm:mt-6 pb-10 sm:pb-8 text-theme-secondary text-xs font-medium transition-colors"
  >
    <div class="flex flex-col items-center gap-2 sm:hidden">
      <a
        href={privacyUrl}
        class="text-xs text-accent-green font-medium flex items-center font-body"
        aria-label="Privacy Policy">Privacy</a
      >
      <p class="text-xs flex items-center font-body">© {currentYear} AUXO</p>
      <a
        href={privacyUrl}
        class="flex items-center gap-1 text-xs text-accent-green font-medium font-body"
        aria-label="PDPL Compliant"
      >
        <Icon
          name="mdi:shield-check"
          class="w-3.5 h-3.5 text-accent-green flex-shrink-0"
        />
        <span>PDPL</span>
      </a>
    </div>
    <div
      class="hidden sm:flex sm:flex-row items-center justify-center gap-3 sm:gap-4 lg:gap-5 flex-wrap"
    >
      <p class="text-center font-body">
        © {currentYear} AUXO Data Labs. All rights reserved.
      </p>
      <span class="text-theme-tertiary" aria-hidden="true">•</span>
      <span class="flex items-center gap-2 whitespace-nowrap font-body">
        <Icon
          name="mdi:map-marker-outline"
          class="w-4 h-4 text-accent-green flex-shrink-0 transition-colors"
        />
        <span>Dubai, UAE</span>
      </span>
      <span class="text-theme-tertiary" aria-hidden="true">•</span>
      <a
        href={privacyUrl}
        class="flex items-center gap-2 whitespace-nowrap px-3 py-1.5 bg-accent-green/10 border border-accent-green rounded-lg hover:bg-accent-green/20 transition-all duration-fast group min-h-[var(--touch-target-min)] font-body"
        aria-label="View Privacy Policy - PDPL Compliant"
      >
        <Icon
          name="mdi:shield-check"
          class="w-4 h-4 text-accent-green flex-shrink-0 transition-colors group-hover:scale-110"
        />
        <span class="text-xs font-semibold text-accent-green"
          >PDPL Compliant</span
        >
      </a>
    </div>
  </div>
</footer>

<style>
  .footer-accordion summary::-webkit-details-marker,
  .footer-accordion summary::marker {
    display: none;
  }
</style>
