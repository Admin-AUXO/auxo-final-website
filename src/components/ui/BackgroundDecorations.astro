---
export interface Props {
  gradients?: ("hero" | "center" | "dual" | "top")[];
  patterns?: ("grid" | "mesh")[];
  class?: string;
}

const {
  gradients = [],
  patterns = [],
  class: className = "",
} = Astro.props;

const gradientClasses = {
  hero: "section-gradient-hero",
  center: "section-gradient-center",
  dual: "section-gradient-dual",
  top: "section-gradient-top",
};

const patternClasses = {
  grid: "section-pattern-grid",
  mesh: "section-pattern-mesh",
};

const decorationClasses = [
  ...gradients.map((gradient) => gradientClasses[gradient]),
  ...patterns.map((pattern) => patternClasses[pattern]),
];
---

{decorationClasses.map((decorationClass) => (
  <div
    class={`${decorationClass} absolute inset-0 pointer-events-none -z-10 ${className}`}
  ></div>
))}


