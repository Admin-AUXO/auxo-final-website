---
import { Icon } from "astro-icon/components";
import SectionContainer from "@/components/layouts/SectionContainer.astro";
import BackgroundDecorations from "@/components/ui/BackgroundDecorations.astro";
import HighlightText from "@/components/ui/HighlightText.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";

interface Props {
  content: {
    title: string;
    description: string;
    descriptionHighlight?: string | string[];
  };
}

const { content } = Astro.props;
const metrics = [
  { 
    icon: "mdi:map-marker-outline", 
    label: "Dubai", 
    sublabel: "Base",
    description: "Headquartered in the heart of the Middle East"
  },
  { 
    icon: "mdi:web", 
    label: "Global", 
    sublabel: "Reach",
    description: "Supporting clients across regions and time zones"
  },
  { 
    icon: "mdi:clock-outline", 
    label: "Flexible", 
    sublabel: "Engagements",
    description: "Remote, hybrid, or on-site—as needed"
  },
];
---

<SectionContainer
  id="global"
  padding="sm"
  background="elevated"
  class="relative global-section section-divider"
>
  <BackgroundDecorations gradients={["dual"]} patterns={["mesh"]} />
  
  <div class="grid-container relative z-10">
    <div class="col-span-full max-w-[1400px] mx-auto w-full">
      <SectionHeader
        title={content.title}
        subtitle={content.description}
        subtitleHighlight={content.descriptionHighlight}
        icon="mdi:earth"
        center={false}
        wrapperClass="about-section-header"
        subtitleClass="max-w-none mx-0"
      />

      <div class="about-global-layout">
        <div class="about-global-metrics">
          {metrics.map((metric, index) => (
            <article
              class="about-global-metric"
              data-reveal="fade-up"
              data-reveal-delay={index * 40}
              data-reveal-duration="200"
              data-reveal-easing="ease-out"
            >
              <div class="about-global-metric-icon">
                <Icon name={metric.icon} class="w-5 h-5 text-accent-green" />
              </div>
              <div class="about-global-metric-body">
                <p class="about-global-metric-title">{metric.label}</p>
                <p class="about-global-metric-kicker">{metric.sublabel}</p>
                <p class="about-global-metric-copy">{metric.description}</p>
              </div>
            </article>
          ))}
        </div>

        <div
          class="about-global-statement"
          data-reveal="fade-up"
          data-reveal-delay="120"
          data-reveal-duration="200"
          data-reveal-easing="ease-out"
        >
          <p class="about-global-statement-label">Delivery Model</p>
          <p class="about-global-statement-copy">
            <HighlightText
              text={content.description}
              highlight={content.descriptionHighlight}
            />
          </p>
        </div>
      </div>
    </div>
  </div>
</SectionContainer>

