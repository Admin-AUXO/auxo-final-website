---
import { Icon } from "astro-icon/components";
import SectionShell from "@/components/layouts/SectionShell.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";

interface Props {
  content: {
    title: string;
    description: string;
    profiles: {
      title: string;
      focus: string;
      description: string;
      icon: string;
    }[];
    note: string;
  };
}

const { content } = Astro.props;
---

<SectionShell
  id="team"
  padding="sm"
  background="default"
  contentWidth="6xl"
  class="relative team-section section-divider"
>
  <div class="team-accent-bars absolute inset-0 pointer-events-none -z-10"></div>
  <div class="team-gradient absolute inset-0 pointer-events-none -z-10"></div>

  <SectionHeader
    title={content.title}
    subtitle={content.description}
    highlight="AUXO"
    center={false}
    wrapperClass="about-section-header"
    subtitleClass="max-w-none mx-0"
  />

  <div class="about-team-layout">
    <aside
      class="about-team-rail"
      data-reveal="fade-up"
      data-reveal-delay="0"
      data-reveal-duration="200"
      data-reveal-easing="ease-out"
    >
      <p class="about-team-rail-label">Operating Model</p>
      <p class="about-team-rail-copy">{content.note}</p>
    </aside>

    <div class="about-team-rows">
      {content.profiles.map((profile, index) => (
        <article
          class="about-team-row"
          data-reveal="fade-up"
          data-reveal-delay={40 + index * 40}
          data-reveal-duration="200"
          data-reveal-easing="ease-out"
        >
          <div class="about-team-row-icon">
            <Icon name={profile.icon} class="w-5 h-5 text-accent-green" />
          </div>
          <div class="about-team-row-body">
            <p class="about-team-row-focus">{profile.focus}</p>
            <h3 class="about-team-row-title">{profile.title}</h3>
            <p class="about-team-row-copy">{profile.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</SectionShell>
