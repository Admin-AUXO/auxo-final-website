---
import { Icon } from "astro-icon/components";
import SectionShell from "@/components/layouts/SectionShell.astro";
import HighlightText from "@/components/ui/HighlightText.astro";

interface Props {
  content: {
    title: string;
    description: string;
    leadership: {
      name: string;
      role: string;
      bio: string;
    }[];
    advisors: {
      name: string;
      role: string;
      bio: string;
    }[];
  };
}

const { content } = Astro.props;
const groups = [
  {
    title: "Leadership",
    icon: "mdi:briefcase-outline",
    people: content.leadership,
  },
  {
    title: "Advisors",
    icon: "mdi:account-tie",
    people: content.advisors,
  },
].filter((group) => group.people.length > 0);
---

<SectionShell
  id="team"
  padding="normal"
  background="default"
  contentWidth="6xl"
  class="relative team-section"
>
  <div class="team-accent-bars absolute inset-0 pointer-events-none -z-10"></div>
  <div class="team-gradient absolute inset-0 pointer-events-none -z-10"></div>
  <div
    class="text-center mb-10 sm:mb-12 lg:mb-16 xl:mb-20"
    data-reveal="fade-down"
    data-reveal-duration="200"
    data-reveal-easing="ease-out"
  >
    <div class="inline-flex items-center justify-center gap-3 mb-4 sm:mb-6">
      <Icon
        name="mdi:account-group"
        class="w-8 h-8 sm:w-10 sm:h-10 text-accent-green"
      />
      <h2
        class="text-h2 font-extrabold text-theme-primary leading-tight tracking-tight font-display"
      >
        <HighlightText
          text={content.title}
          highlight="AUXO"
          highlightClass="text-accent-green font-black"
        />
      </h2>
    </div>
    <p
      class="text-body-lg sm:text-body-xl text-theme-secondary leading-relaxed max-w-3xl mx-auto font-body px-4 sm:px-6"
    >
      <HighlightText
        text={content.description}
        highlight={["consultants", "data engineers", "data scientists"]}
        highlightClass="text-accent-green font-bold"
      />
    </p>
  </div>

  {
    groups.map((group, groupIndex) => (
      <div class={groupIndex === 0 ? "mb-12 sm:mb-16" : ""}>
        <h3
          class="text-h3 font-bold text-theme-primary mb-6 sm:mb-8 text-center font-display"
          data-reveal="fade-up"
          data-reveal-delay="0"
          data-reveal-duration="200"
          data-reveal-easing="ease-out"
        >
          {group.title}
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
          {group.people.map((person, index) => (
            <div
              class="team-member-card group relative h-full flex flex-col"
              data-reveal="fade-up"
              data-reveal-delay={50 + index * 40}
              data-reveal-duration="200"
              data-reveal-easing="ease-out"
            >
              <div class="bg-theme-surface/80 backdrop-blur-sm border border-theme-light rounded-3xl p-8 h-full lg:hover:border-accent-green/40 transition-all duration-300 shadow-lg lg:hover:shadow-xl relative overflow-hidden flex flex-col">
                <div class="absolute top-0 right-0 w-32 h-32 bg-accent-green/10 rounded-full blur-3xl opacity-0 lg:group-hover:opacity-100 transition-opacity duration-500 pointer-events-none -mr-10 -mt-10" />

                <div class="relative z-10 flex-grow">
                  <h4 class="text-2xl font-extrabold text-theme-primary mb-1 font-display tracking-tight">
                    {person.name}
                  </h4>
                  <p class="text-accent-green font-bold mb-5 text-body-base sm:text-body-lg font-body flex items-center gap-2">
                    <Icon name={group.icon} class="w-4 h-4 opacity-70" />
                    {person.role}
                  </p>
                  <p class="text-body-lg text-theme-secondary leading-[1.65] font-body">
                    {person.bio}
                  </p>
                </div>

                <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-accent-green/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
              </div>
            </div>
          ))}
        </div>
      </div>
    ))
  }

      {
        content.leadership.length === 0 && content.advisors.length === 0 && (
          <div
            class="text-center py-12 sm:py-16"
            data-reveal="fade-up"
            data-reveal-delay="50"
            data-reveal-duration="200"
            data-reveal-easing="ease-out"
          >
            <p class="text-body-lg text-theme-secondary font-body">
              Leadership bios and advisor information coming soon.
            </p>
          </div>
        )
      }
</SectionShell>
