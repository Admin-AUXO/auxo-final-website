---
import { Icon } from "astro-icon/components";
import SectionShell from "@/components/layouts/SectionShell.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";

interface Props {
  content: {
    title: string;
    description: string;
    profiles: {
      title: string;
      focus: string;
      description: string;
      icon: string;
    }[];
    note: string;
  };
}

const { content } = Astro.props;
---

<SectionShell
  id="team"
  padding="normal"
  background="default"
  contentWidth="6xl"
  class="relative team-section section-divider"
>
  <div class="team-accent-bars absolute inset-0 pointer-events-none -z-10"></div>
  <div class="team-gradient absolute inset-0 pointer-events-none -z-10"></div>

  <SectionHeader
    title={content.title}
    subtitle={content.description}
    highlight="AUXO"
  />

  <div class="about-team-grid">
    {content.profiles.map((profile, index) => (
      <article
        class="about-team-card"
        data-reveal="fade-up"
        data-reveal-delay={index * 40}
        data-reveal-duration="200"
        data-reveal-easing="ease-out"
      >
        <div class="about-team-card-head">
          <div class="about-team-card-icon">
            <Icon name={profile.icon} class="w-6 h-6 text-accent-green" />
          </div>
          <div>
            <p class="about-team-card-focus">{profile.focus}</p>
            <h3 class="about-team-card-title">{profile.title}</h3>
          </div>
        </div>
        <p class="about-team-card-copy">{profile.description}</p>
      </article>
    ))}
  </div>

  <div
    class="about-team-note"
    data-reveal="fade-up"
    data-reveal-delay="120"
    data-reveal-duration="200"
    data-reveal-easing="ease-out"
  >
    <Icon name="mdi:account-group-outline" class="w-5 h-5 text-accent-green" />
    <p>{content.note}</p>
  </div>
</SectionShell>
