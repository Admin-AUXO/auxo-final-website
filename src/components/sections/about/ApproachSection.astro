---
import { Icon } from "astro-icon/components";
import SectionShell from "@/components/layouts/SectionShell.astro";
import HighlightText from "@/components/ui/HighlightText.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";

interface Props {
  content: {
    title: string;
    description: string;
    descriptionHighlight?: string | string[];
    principles: {
      letter: string;
      title: string;
      description: string;
      descriptionHighlight?: string | string[];
    }[];
  };
}

const { content } = Astro.props;
const principleIcons = {
  C: "mdi:crosshairs-gps",
  O: "mdi:file-tree",
  D: "mdi:hammer-wrench",
  E: "mdi:check-decagram",
};
---

<SectionShell
  id="approach"
  padding="sm"
  background="elevated"
  gradients={["dual"]}
  patterns={["grid"]}
  contentWidth="screen"
  class="relative approach-section section-divider"
>
  <SectionHeader
    title={content.title}
    subtitle={content.description}
    subtitleHighlight={content.descriptionHighlight}
    highlight="How We Work"
    center={false}
    wrapperClass="about-section-header"
    subtitleClass="max-w-none mx-0"
  />

  <div class="about-code-grid">
    {content.principles.map((principle, index) => (
      <article
        class="about-code-line"
        data-reveal="fade-up"
        data-reveal-delay={index * 40}
        data-reveal-duration="200"
        data-reveal-easing="ease-out"
      >
        <div class="about-code-badge">
          <span class="about-code-letter">{principle.letter}</span>
          <Icon
            name={principleIcons[principle.letter as keyof typeof principleIcons]}
            class="w-4.5 h-4.5 text-accent-green"
          />
        </div>
        <div class="about-code-body">
          <h3 class="about-code-title">{principle.title}</h3>
          <p class="about-code-copy">
            <HighlightText
              text={principle.description}
              highlight={principle.descriptionHighlight}
            />
          </p>
        </div>
      </article>
    ))}
  </div>
</SectionShell>
