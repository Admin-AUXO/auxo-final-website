---
import { Icon } from "astro-icon/components";
import SectionShell from "@/components/layouts/SectionShell.astro";
import HighlightText from "@/components/ui/HighlightText.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import Carousel from "@/components/ui/Carousel.astro";

interface Props {
  content: {
    title: string;
    description: string;
    descriptionHighlight?: string | string[];
    principles: {
      letter: string;
      title: string;
      description: string;
      descriptionHighlight?: string | string[];
    }[];
  };
}

const { content } = Astro.props;
const principleIcons = {
  C: "mdi:crosshairs-gps",
  O: "mdi:file-tree",
  D: "mdi:hammer-wrench",
  E: "mdi:check-decagram",
};
---

<SectionShell
  id="approach"
  padding="normal"
  background="elevated"
  gradients={["dual"]}
  patterns={["grid"]}
  contentWidth="screen"
  class="relative approach-section section-divider"
>
  <SectionHeader
    title={content.title}
    subtitle={content.description}
    highlight="CODE"
    highlightClass="text-accent-green font-black text-[1.15em]"
  />

      <div
        class="hidden md:grid md:grid-cols-2 gap-6 sm:gap-8 lg:gap-10 code-principles-desktop"
      >
        {
          content.principles.map((principle, index) => (
            <div
              class="code-principle-card group relative h-full flex flex-col"
              data-reveal="fade-up"
              data-reveal-delay={index * 50}
              data-reveal-duration="250"
              data-reveal-easing="ease-out"
            >
              <div class="h-full bg-theme-surface/80 backdrop-blur-sm border border-accent-green/20 rounded-3xl p-8 relative overflow-hidden lg:hover:border-accent-green/40 transition-colors duration-300 shadow-lg lg:hover:shadow-xl flex flex-col">
                <div class="absolute top-0 right-0 w-32 h-32 bg-accent-green/10 rounded-full blur-3xl opacity-0 lg:group-hover:opacity-100 transition-opacity duration-500 pointer-events-none -mr-10 -mt-10" />
                <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-accent-green/0 via-accent-green/30 to-accent-green/0 lg:group-hover:via-accent-green/50 transition-colors duration-300 rounded-t-3xl" />

                <div class="relative z-10 flex-grow flex flex-col">
                  <div class="flex items-center gap-4 mb-5">
                    <div class="flex-shrink-0 w-14 h-14 bg-accent-green/15 rounded-2xl flex items-center justify-center border border-accent-green/30 group-hover:shadow-[0_0_20px_rgba(200,245,96,0.15)] transition-all duration-300">
                      <Icon
                        name={
                          principleIcons[
                            principle.letter as keyof typeof principleIcons
                          ]
                        }
                        class="w-7 h-7 text-accent-green"
                      />
                    </div>
                    <h3 class="text-h4 font-bold text-theme-primary font-display flex items-baseline">
                      <span class="text-accent-green font-black text-3xl mr-1">
                        {principle.letter}
                      </span>
                      <span>
                        {principle.title.slice(principle.letter.length)}
                      </span>
                    </h3>
                  </div>
                  <p class="text-body-lg text-theme-secondary leading-[1.65] font-body flex-grow">
                    {principle.description}
                  </p>
                </div>

                <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-accent-green/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
              </div>
            </div>
          ))
        }
      </div>

      <div class="approach-carousel-section">
        <Carousel
          containerId="code-carousel-container"
          trackId="code-carousel-track"
          items={content.principles}
          wrapperClass="md:hidden code-principles-carousel code-principles-carousel-wrapper"
          breakpoint={768}
        >
          {
            content.principles.map((principle, index) => (
              <div class="carousel-slide embla__slide" data-index={index}>
                <div class="carousel-card-about group lg:hover:border-accent-green/40">
                  <div class="absolute top-0 right-0 w-24 h-24 bg-accent-green/5 rounded-full blur-2xl opacity-0 lg:group-hover:opacity-100 transition-opacity duration-500" />
                  <div class="relative z-10 flex flex-col h-full">
                    <div class="flex items-center justify-between mb-2.5">
                      <h3 class="font-bold text-theme-primary font-display flex items-baseline">
                        <span class="text-accent-green font-black text-[1.2em] code-letter">
                          {principle.letter}
                        </span>
                        <span class="code-title-rest">
                          {principle.title.slice(principle.letter.length)}
                        </span>
                      </h3>
                      <div class="w-9 h-9 sm:w-10 sm:h-10 bg-accent-green/10 rounded-lg flex items-center justify-center lg:group-hover:bg-accent-green/20 transition-colors duration-300 flex-shrink-0 ml-3">
                        <Icon
                          name={
                            principleIcons[
                              principle.letter as keyof typeof principleIcons
                            ]
                          }
                          class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-accent-green"
                        />
                      </div>
                    </div>

                    <p class="text-theme-secondary leading-relaxed font-body flex-grow">
                      {principle.description}
                    </p>
                  </div>
                </div>
              </div>
            ))
          }
        </Carousel>
      </div>
</SectionShell>
