---
import { Icon } from "astro-icon/components";
import SectionShell from "@/components/layouts/SectionShell.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import HighlightText from "@/components/ui/HighlightText.astro";

interface Props {
  content: {
    title: string;
    description: string;
    descriptionHighlight?: string | string[];
    capabilities: {
      title: string;
      description: string;
      icon: string;
    }[];
    nameOrigin: {
      title: string;
      description: string;
      descriptionHighlight?: string | string[];
    };
  };
}

const { content } = Astro.props;
---

<SectionShell
  id="purpose"
  padding="sm"
  background="card"
  gradients={["center"]}
  patterns={["mesh"]}
  contentWidth="6xl"
  class="relative purpose-section section-divider"
>
  <SectionHeader
    title={content.title}
    subtitle={content.description}
    subtitleHighlight={content.descriptionHighlight}
    center={false}
    wrapperClass="about-section-header"
    subtitleClass="max-w-none mx-0"
  />

  <div class="about-purpose-layout">
    <div class="about-purpose-list">
      {content.capabilities.map((capability, index) => (
        <article
          class="about-purpose-row"
          data-reveal="fade-up"
          data-reveal-delay={index * 40}
          data-reveal-duration="200"
          data-reveal-easing="ease-out"
        >
          <div class="about-purpose-row-icon">
            <Icon name={capability.icon} class="w-5 h-5 text-accent-green" />
          </div>
          <div class="about-purpose-row-body">
            <h3 class="about-purpose-row-title">{capability.title}</h3>
            <p class="about-purpose-row-copy">{capability.description}</p>
          </div>
        </article>
      ))}
    </div>

    <aside
      class="about-origin-rail"
      data-reveal="fade-up"
      data-reveal-delay="120"
      data-reveal-duration="200"
      data-reveal-easing="ease-out"
    >
      <p class="about-origin-rail-label">{content.nameOrigin.title}</p>
      <p class="about-origin-rail-copy">
        <HighlightText
          text={content.nameOrigin.description}
          highlight={content.nameOrigin.descriptionHighlight}
        />
      </p>
    </aside>
  </div>

</SectionShell>
