---
import { Icon } from "astro-icon/components";
import SectionShell from "@/components/layouts/SectionShell.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import HighlightText from "@/components/ui/HighlightText.astro";

interface Props {
  content: {
    title: string;
    description: string;
    descriptionHighlight?: string | string[];
    capabilities: {
      title: string;
      description: string;
      icon: string;
    }[];
    nameOrigin: {
      title: string;
      description: string;
      descriptionHighlight?: string | string[];
    };
  };
}

const { content } = Astro.props;
---

<SectionShell
  id="purpose"
  padding="normal"
  background="card"
  gradients={["center"]}
  patterns={["mesh"]}
  contentWidth="6xl"
  class="relative purpose-section section-divider"
>
  <SectionHeader
    title={content.title}
    subtitle={content.description}
    subtitleHighlight={content.descriptionHighlight}
  />

  <div class="about-purpose-grid">
    {content.capabilities.map((capability, index) => (
      <article
        class="about-purpose-card"
        data-reveal="fade-up"
        data-reveal-delay={index * 40}
        data-reveal-duration="200"
        data-reveal-easing="ease-out"
      >
        <div class="about-purpose-card-head">
          <div class="about-purpose-card-icon">
            <Icon name={capability.icon} class="w-6 h-6 text-accent-green" />
          </div>
          <h3 class="about-purpose-card-title">{capability.title}</h3>
        </div>
        <p class="about-purpose-card-copy">{capability.description}</p>
      </article>
    ))}
  </div>

  <div
    class="about-origin-note"
    data-reveal="fade-up"
    data-reveal-delay="120"
    data-reveal-duration="200"
    data-reveal-easing="ease-out"
  >
    <div class="about-origin-note-head">
      <Icon name="mdi:lightbulb-on-outline" class="w-5 h-5 text-accent-green" />
      <h3>{content.nameOrigin.title}</h3>
    </div>
    <p>
      <HighlightText
        text={content.nameOrigin.description}
        highlight={content.nameOrigin.descriptionHighlight}
      />
    </p>
  </div>
</SectionShell>
