---
import SectionContainer from "@/components/layouts/SectionContainer.astro";
import BackgroundDecorations from "@/components/ui/BackgroundDecorations.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import HighlightText from "@/components/ui/HighlightText.astro";

interface Props {
  content: {
    title: string;
    missionText: string;
    missionHighlight?: string | string[];
    visionText: string;
    visionHighlight?: string | string[];
  };
}

const { content } = Astro.props;
---

<SectionContainer
  id="mission-vision"
  padding="sm"
  background="default"
  class="relative mission-vision-section section-divider"
>
  <BackgroundDecorations gradients={["hero"]} />

  <div class="grid-container relative z-10">
    <div class="col-span-full max-w-[1400px] mx-auto w-full">
      <SectionHeader
        title={content.title}
        highlight={["Mission", "Vision"]}
        center={false}
        wrapperClass="about-section-header"
      />

      <div class="about-direction-grid">
        <article
          class="about-direction-panel"
          data-reveal="fade-right"
          data-reveal-delay="0"
          data-reveal-duration="200"
          data-reveal-easing="ease-out"
        >
          <p class="about-direction-label">Mission</p>
          <p class="about-direction-copy">
            <HighlightText
              text={content.missionText}
              highlight={content.missionHighlight}
            />
          </p>
        </article>

        <article
          class="about-direction-panel"
          data-reveal="fade-left"
          data-reveal-delay="50"
          data-reveal-duration="200"
          data-reveal-easing="ease-out"
        >
          <p class="about-direction-label">Vision</p>
          <p class="about-direction-copy">
            <HighlightText
              text={content.visionText}
              highlight={content.visionHighlight}
            />
          </p>
        </article>
      </div>
    </div>
  </div>
</SectionContainer>
