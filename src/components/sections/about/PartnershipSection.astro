---
import { Icon } from "astro-icon/components";
import SectionShell from "@/components/layouts/SectionShell.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";

interface Props {
  content: {
    title: string;
    description: string;
    descriptionHighlight?: string | string[];
    commitments: {
      title: string;
      description: string;
      icon: string;
    }[];
  };
}

const { content } = Astro.props;
---

<SectionShell
  id="partnership"
  padding="normal"
  background="card"
  contentWidth="6xl"
  class="relative partnership-section section-divider"
>
  <div class="partnership-pattern absolute inset-0 pointer-events-none -z-10"></div>
  <div class="partnership-gradient absolute inset-0 pointer-events-none -z-10"></div>

  <SectionHeader
    title={content.title}
    subtitle={content.description}
    subtitleHighlight={content.descriptionHighlight}
  />

  <div class="about-commitment-grid">
    {content.commitments.map((commitment, index) => (
      <article
        class="about-commitment-card"
        data-reveal="fade-up"
        data-reveal-delay={index * 40}
        data-reveal-duration="200"
        data-reveal-easing="ease-out"
      >
        <div class="about-commitment-card-head">
          <div class="about-commitment-card-icon">
            <Icon name={commitment.icon} class="w-5 h-5 text-accent-green" />
          </div>
          <h3 class="about-commitment-card-title">{commitment.title}</h3>
        </div>
        <p class="about-commitment-card-copy">{commitment.description}</p>
      </article>
    ))}
  </div>
</SectionShell>
