---
import { Icon } from "astro-icon/components";
import SectionShell from "@/components/layouts/SectionShell.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";

interface Props {
  content: {
    title: string;
    description: string;
    descriptionHighlight?: string | string[];
    commitments: {
      title: string;
      description: string;
      icon: string;
    }[];
  };
}

const { content } = Astro.props;
---

<SectionShell
  id="partnership"
  padding="sm"
  background="card"
  contentWidth="6xl"
  class="relative partnership-section section-divider"
>
  <div class="partnership-pattern absolute inset-0 pointer-events-none -z-10"></div>
  <div class="partnership-gradient absolute inset-0 pointer-events-none -z-10"></div>

  <SectionHeader
    title={content.title}
    subtitle={content.description}
    subtitleHighlight={content.descriptionHighlight}
    center={false}
    wrapperClass="about-section-header"
    subtitleClass="max-w-none mx-0"
  />

  <div class="about-partnership-strip">
    {content.commitments.map((commitment, index) => (
      <article
        class="about-partnership-promise"
        data-reveal="fade-up"
        data-reveal-delay={index * 40}
        data-reveal-duration="200"
        data-reveal-easing="ease-out"
      >
        <div class="about-partnership-promise-top">
          <div class="about-partnership-promise-icon">
            <Icon name={commitment.icon} class="w-4.5 h-4.5 text-accent-green" />
          </div>
          <h3 class="about-partnership-promise-title">{commitment.title}</h3>
        </div>
        <p class="about-partnership-promise-copy">{commitment.description}</p>
      </article>
    ))}
  </div>
</SectionShell>
