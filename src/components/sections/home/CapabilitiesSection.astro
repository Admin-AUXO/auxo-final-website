---
import SectionShell from '@/components/layouts/SectionShell.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import { Icon } from "astro-icon/components";
import type { HomepageContent } from "@/data/content";

interface Props {
  content: HomepageContent["capabilities"];
}

const { content } = Astro.props;
---

<SectionShell
  id="capabilities"
  padding="lg"
  background="surface"
  gradients={["center"]}
  patterns={["mesh"]}
  contentWidth="screen"
  class="relative capabilities-section section-divider"
>
  <div data-reveal="fade-down" data-reveal-duration="250" data-reveal-easing="ease-out">
    <SectionHeader
      title={content.title}
      subtitle={content.subheading}
      highlight="Core Capabilities"
    />
  </div>

  <div class="home-capability-routes">
    {content.pillars.map((pillar, index) => (
      <article
        class="home-capability-route"
        data-reveal="fade-up"
        data-reveal-delay={index * 50}
        data-reveal-duration="250"
        data-reveal-easing="ease-out"
      >
        <div class="home-capability-route-intro">
          <div class="home-capability-route-heading">
            <span class="home-capability-route-number">{String(index + 1).padStart(2, "0")}</span>
            <h3 class="home-capability-route-title">{pillar.name}</h3>
          </div>
          <p class="home-capability-route-summary">{pillar.summary}</p>
        </div>
        <p class="home-capability-route-outcome">{pillar.outcome}</p>
        <div class="home-capability-route-skills">
          {pillar.capabilities.map((capability) => (
            <div class="home-capability-skill">
              <div class="home-capability-skill-icon">
                <Icon name={capability.icon} class="w-5 h-5 text-accent-green" />
              </div>
              <div class="home-capability-skill-body">
                <p class="home-capability-skill-title">{capability.title}</p>
                <p class="home-capability-skill-copy">{capability.description}</p>
              </div>
            </div>
          ))}
        </div>
      </article>
    ))}
  </div>
</SectionShell>

