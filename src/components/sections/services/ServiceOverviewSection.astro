---
import { Icon } from "astro-icon/components";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import SectionShell from "@/components/layouts/SectionShell.astro";
import type { ServicePageDetail } from "@/data/content/service-page-details";

interface Props {
  service: ServicePageDetail;
}

type OverviewGroup = {
  key: string;
  title: string;
  icon: string;
  items: string[];
  cardClass: string;
  headerBorderClass: string;
  iconWrapperClass: string;
  iconClass: string;
  itemClass: string;
  itemIndexClass: string;
  itemTextClass: string;
  summaryIndicatorClass: string;
  reveal: string;
};

const { service } = Astro.props;

const overviewGroups: OverviewGroup[] = [
  {
    key: "challenges",
    title: "Where teams usually get stuck",
    icon: "mdi:alert-circle-outline",
    items: service.overview.challenges,
    cardClass: "service-overview-card service-overview-card-challenges",
    headerBorderClass: "service-overview-card-border",
    iconWrapperClass: "service-overview-icon-wrap service-overview-icon-wrap-challenges",
    iconClass: "text-theme-primary",
    itemClass:
      "service-overview-item service-overview-item-challenges",
    itemIndexClass: "service-overview-item-index service-overview-item-index-challenges",
    itemTextClass: "text-theme-secondary/90",
    summaryIndicatorClass: "service-overview-summary-indicator service-overview-summary-indicator-challenges",
    reveal: "fade-right",
  },
  {
    key: "solutions",
    title: "How AUXO fixes the problem",
    icon: "mdi:check-circle-outline",
    items: service.overview.solutions,
    cardClass: "service-overview-card service-overview-card-solutions",
    headerBorderClass: "service-overview-card-border",
    iconWrapperClass: "service-overview-icon-wrap service-overview-icon-wrap-solutions",
    iconClass: "text-accent-green",
    itemClass:
      "service-overview-item service-overview-item-solutions",
    itemIndexClass: "service-overview-item-index service-overview-item-index-solutions",
    itemTextClass: "text-theme-secondary/90",
    summaryIndicatorClass: "service-overview-summary-indicator service-overview-summary-indicator-solutions",
    reveal: "fade-left",
  },
];
---

<SectionShell
  id="service-overview"
  padding="normal"
  background="elevated"
  gradients={["dual"]}
  patterns={["grid"]}
  contentWidth="6xl"
  class="relative service-overview-section section-divider"
>
  <div
    data-reveal="fade-down"
    data-reveal-duration="200"
    data-reveal-easing="ease-out"
  >
    <SectionHeader
      title={service.overview.title}
      subtitle={service.overview.description}
      subtitleHighlight={service.overview.descriptionHighlight}
    />
  </div>

  <div class="hidden lg:grid lg:grid-cols-2 gap-6 lg:gap-8 xl:gap-10 service-overview-desktop">
    {overviewGroups.map((group) => (
      <div
        class={group.cardClass}
        data-reveal={group.reveal}
        data-reveal-delay="50"
        data-reveal-duration="200"
        data-reveal-easing="ease-out"
      >
        <div class={`flex items-center gap-3 pb-6 mb-6 min-h-[4.5rem] ${group.headerBorderClass}`}>
          <div
            class={`w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0 ${group.iconWrapperClass}`}
          >
            <Icon name={group.icon} class={`w-6 h-6 ${group.iconClass}`} />
          </div>
          <h3
            class="text-xl sm:text-2xl font-bold text-theme-primary font-display line-clamp-2"
          >
            {group.title}
          </h3>
        </div>

        <div class="space-y-4 flex-1">
          {group.items.map((item, index) => (
            <div class={group.itemClass}>
              <div
                class={`w-7 h-7 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5 ${group.itemIndexClass}`}
              >
                <span class="text-sm font-bold font-display">{index + 1}</span>
              </div>
              <p class={`text-sm sm:text-base leading-relaxed font-body ${group.itemTextClass}`}>
                {item}
              </p>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

  <div class="lg:hidden space-y-3 service-overview-mobile">
    {overviewGroups.map((group, index) => (
      <details
        class={`service-accordion-item rounded-xl overflow-hidden group ${group.cardClass}`}
        open={index === 0}
      >
        <summary
          class="service-accordion-summary flex items-center justify-between gap-3 p-4"
        >
          <div class="flex items-center gap-3 flex-1 min-w-0 pointer-events-none">
            <div
              class={`w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 ${group.iconWrapperClass}`}
            >
              <Icon name={group.icon} class={`w-5 h-5 ${group.iconClass}`} />
            </div>
            <h3 class="text-base font-bold text-theme-primary font-display truncate">
              {group.title}
            </h3>
          </div>
          <div
            class={`service-accordion-indicator flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center pointer-events-none ${group.summaryIndicatorClass}`}
          >
            <Icon
              name="mdi:chevron-down"
              class="w-4 h-4 transition-transform duration-300 group-open:rotate-180"
            />
          </div>
        </summary>

        <div class="service-accordion-content">
          <div class="px-4 pb-4 space-y-3">
            {group.items.map((item, itemIndex) => (
              <div
                class={group.itemClass}
              >
                <div
                  class={`w-6 h-6 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5 ${group.itemIndexClass.replace("w-7 h-7 ", "")}`}
                >
                  <span class="text-xs font-bold font-display">{itemIndex + 1}</span>
                </div>
                <p class="text-sm text-theme-secondary leading-relaxed font-body flex-1">
                  {item}
                </p>
              </div>
            ))}
          </div>
        </div>
      </details>
    ))}
  </div>
</SectionShell>

