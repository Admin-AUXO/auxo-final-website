---
import { Icon } from "astro-icon/components";
import HighlightText from "@/components/ui/HighlightText.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import SectionShell from "@/components/layouts/SectionShell.astro";

interface Props {
  content: {
    title: string;
    description: string;
    descriptionHighlight?: string | string[];
    models: {
      name: string;
      subheadline: string;
      description: string;
      descriptionHighlight?: string | string[];
      bestFor: string;
      bestForHighlight?: string | string[];
      deliverables: string[];
      pricingRange: string;
      typicalTimeframe: string;
    }[];
  };
}

const { content } = Astro.props;

const modelIcons = [
  "mdi:map-search",
  "mdi:waves",
  "mdi:cogs",
  "mdi:account-tie",
];
---

<SectionShell
  id="models"
  padding="normal"
  background="elevated"
  gradients={["dual"]}
  patterns={["grid"]}
  contentWidth="6xl"
  class="relative models-section section-divider"
>
  <div
    class="mb-8 sm:mb-10 lg:mb-12"
    data-reveal="fade-down"
    data-reveal-duration="200"
    data-reveal-easing="ease-out"
  >
    <SectionHeader
      title={content.title}
      subtitle={content.description}
      subtitleHighlight={content.descriptionHighlight}
      highlight="Engagement Model"
      icon="mdi:clipboard-text-outline"
    />
  </div>

      <div
        class="mb-8 sm:mb-10 lg:mb-12"
        data-reveal="fade-up"
        data-reveal-delay="50"
        data-reveal-duration="200"
        data-reveal-easing="ease-out"
      >
        <div class="models-accordion-container" role="presentation">
          {
            content.models.map((model, index) => (
              <details
                class="models-accordion-item group/model"
                data-model={String(index)}
                open={index === 0}
              >
                <summary
                  class="models-accordion-summary"
                  role="button"
                  aria-expanded={index === 0 ? "true" : "false"}
                  aria-controls={`model-content-${index}`}
                >
                  <div class="models-accordion-header pointer-events-none">
                    <div class="models-accordion-step-number">
                      <span>{String(index + 1).padStart(2, "0")}</span>
                    </div>
                    <div class="models-accordion-icon transition-transform duration-300 group-hover/model:scale-110 group-open/model:scale-110 group-open/model:bg-accent-green/20">
                      <Icon
                        name={modelIcons[index]}
                        class="w-5 h-5 sm:w-6 sm:h-6 text-accent-green"
                        aria-hidden="true"
                      />
                    </div>
                    <div class="models-accordion-title-wrapper">
                      <h3 class="models-accordion-title mb-1 group-open/model:text-accent-green transition-colors duration-300">
                        {model.name}
                      </h3>
                      <span class="models-accordion-subheadline block group-open/model:text-theme-primary transition-colors duration-300">
                        {model.subheadline}
                      </span>
                    </div>
                    <div class="models-accordion-header-tags pointer-events-none">
                      <span class="models-accordion-tag models-accordion-tag--time">
                        <Icon
                          name="mdi:clock-outline"
                          class="w-3.5 h-3.5"
                          aria-hidden="true"
                        />
                        {model.typicalTimeframe}
                      </span>
                    </div>
                  </div>
                  <div class="models-accordion-chevron-wrapper">
                    <Icon
                      name="mdi:chevron-down"
                      class="models-accordion-chevron pointer-events-none"
                      aria-hidden="true"
                    />
                  </div>
                </summary>
                <div
                  class="models-accordion-content"
                  id={`model-content-${index}`}
                  role="region"
                  aria-label={`${model.name} details`}
                >
                  <div class="models-accordion-body">
                    <div class="models-accordion-description-wrapper">
                      <p class="models-accordion-description">
                        {model.descriptionHighlight ? (
                          <HighlightText
                            text={model.description}
                            highlight={model.descriptionHighlight}
                          />
                        ) : (
                          model.description
                        )}
                      </p>
                    </div>

                    <div class="models-accordion-stats-strip">
                      <div class="models-accordion-stat-card">
                        <div class="models-accordion-stat-icon-wrapper">
                          <Icon
                            name="mdi:finance"
                            class="w-5 h-5"
                            aria-hidden="true"
                          />
                        </div>
                        <div class="models-accordion-stat-info">
                          <span class="models-accordion-stat-label">
                            Investment Range
                          </span>
                          <span class="models-accordion-stat-value">
                            {model.pricingRange}
                          </span>
                        </div>
                      </div>
                      <div class="models-accordion-stat-card">
                        <div class="models-accordion-stat-icon-wrapper">
                          <Icon
                            name="mdi:clock-outline"
                            class="w-5 h-5"
                            aria-hidden="true"
                          />
                        </div>
                        <div class="models-accordion-stat-info">
                          <span class="models-accordion-stat-label">
                            Typical Timeframe
                          </span>
                          <span class="models-accordion-stat-value">
                            {model.typicalTimeframe}
                          </span>
                        </div>
                      </div>
                    </div>

                    <div class="models-accordion-details-grid">
                      <div class="models-accordion-fit-section">
                        <div class="models-accordion-section-header">
                          <p class="models-accordion-section-label">
                            Strategic Fit
                          </p>
                        </div>
                        <p class="models-accordion-fit-text">
                          {model.bestForHighlight ? (
                            <HighlightText
                              text={model.bestFor}
                              highlight={model.bestForHighlight}
                            />
                          ) : (
                            model.bestFor
                          )}
                        </p>
                      </div>

                      <div class="models-accordion-deliverables-section">
                        <div class="models-accordion-section-header">
                          <p class="models-accordion-section-label">
                            Key Deliverables
                          </p>
                        </div>
                        <div class="models-accordion-deliverables">
                          {model.deliverables.map((deliverable) => (
                            <div class="models-accordion-deliverable-item group/item">
                              <Icon
                                name="mdi:check-circle"
                                class="w-4 h-4 text-accent-green flex-shrink-0 group-hover/item:scale-110 transition-transform"
                                aria-hidden="true"
                              />
                              <span class="models-accordion-deliverable-text">
                                {deliverable}
                              </span>
                            </div>
                          ))}
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </details>
            ))
          }
        </div>

        <div
          class="mt-8 text-center"
          data-reveal="fade-up"
          data-reveal-delay="200"
        >
          <p class="text-sm text-theme-secondary opacity-60 italic">
            * All investment ranges are indicative. Exact pricing is determined
            by project scope, complexity, and specific data requirements.
          </p>
        </div>
      </div>
</SectionShell>

<script>
  document.addEventListener("astro:page-load", () => {
    const accordionItems = document.querySelectorAll(".models-accordion-item");

    accordionItems.forEach((item) => {
      const summary = item.querySelector(".models-accordion-summary");
      if (!summary) return;

      summary.addEventListener("click", (e) => {
        const isOpening = !item.hasAttribute("open");

        summary.setAttribute("aria-expanded", String(isOpening));

        if (!isOpening) return;

        accordionItems.forEach((otherItem) => {
          if (otherItem !== item && otherItem.hasAttribute("open")) {
            otherItem.removeAttribute("open");
            otherItem
              .querySelector(".models-accordion-summary")
              ?.setAttribute("aria-expanded", "false");
          }
        });
      });
    });
  });
</script>
