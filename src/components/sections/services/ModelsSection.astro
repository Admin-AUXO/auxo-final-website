---
import { Icon } from "astro-icon/components";
import HighlightText from "@/components/ui/HighlightText.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import SectionShell from "@/components/layouts/SectionShell.astro";

interface Props {
  content: {
    title: string;
    description: string;
    descriptionHighlight?: string | string[];
    models: {
      name: string;
      subheadline: string;
      description: string;
      descriptionHighlight?: string | string[];
      commercialModel: string;
      workingRhythm: string;
      bestFor: string;
      bestForHighlight?: string | string[];
      deliverables: string[];
      pricingRange: string;
      typicalTimeframe: string;
    }[];
  };
}

const { content } = Astro.props;

const modelIcons = [
  "mdi:map-search",
  "mdi:waves",
  "mdi:cogs",
  "mdi:account-tie",
];
---

<SectionShell
  id="models"
  padding="normal"
  background="elevated"
  gradients={["dual"]}
  patterns={["grid"]}
  contentWidth="6xl"
  class="relative engagement-choice-section section-divider"
>
  <SectionHeader
    title={content.title}
    subtitle={content.description}
    subtitleHighlight={content.descriptionHighlight}
    highlight="Engagement Model"
    icon="mdi:clipboard-text-outline"
  />

      <div
        class="mb-8 sm:mb-10 lg:mb-12"
        data-reveal="fade-up"
        data-reveal-delay="50"
        data-reveal-duration="200"
        data-reveal-easing="ease-out"
      >
        <div class="engagement-choice-grid" role="presentation">
          {
            content.models.map((model, index) => (
              <article class="engagement-choice-card">
                <div class="engagement-choice-card-header">
                  <div class="engagement-choice-index">
                    <span>{String(index + 1).padStart(2, "0")}</span>
                  </div>
                  <div class="engagement-choice-icon">
                    <Icon
                      name={modelIcons[index]}
                      class="w-5 h-5 sm:w-6 sm:h-6 text-accent-green"
                      aria-hidden="true"
                    />
                  </div>
                  <div class="engagement-choice-heading">
                    <h3 class="engagement-choice-title">
                      {model.name}
                    </h3>
                    <span class="engagement-choice-subtitle">
                      {model.subheadline}
                    </span>
                  </div>
                </div>

                <div class="engagement-choice-body">
                  <div class="engagement-choice-overview">
                    <div class="engagement-choice-copy">
                      <p class="engagement-choice-eyebrow">
                        What This Model Solves
                      </p>
                      <p class="engagement-choice-description">
                        {model.descriptionHighlight ? (
                          <HighlightText
                            text={model.description}
                            highlight={model.descriptionHighlight}
                          />
                        ) : (
                          model.description
                        )}
                      </p>
                    </div>

                    <aside class="engagement-choice-facts">
                      <div class="engagement-choice-investment">
                        <p class="engagement-choice-label">Investment Range</p>
                        <p class="engagement-choice-investment-value">{model.pricingRange}</p>
                        <p class="engagement-choice-note">
                          Indicative for senior-led scope
                        </p>
                      </p>
                      </div>

                      <dl class="engagement-choice-meta">
                        <div class="engagement-choice-meta-item">
                          <dt class="engagement-choice-label">Commercial Model</dt>
                          <dd class="engagement-choice-meta-value">{model.commercialModel}</dd>
                        </div>

                        <div class="engagement-choice-meta-item">
                          <dt class="engagement-choice-label">Typical Timeframe</dt>
                          <dd class="engagement-choice-meta-value">{model.typicalTimeframe}</dd>
                        </div>
                      </dl>
                    </aside>
                  </div>

                  <div class="engagement-choice-criteria">
                    <div class="engagement-choice-criterion">
                      <p class="engagement-choice-label">
                        Best When
                      </p>
                      <p class="engagement-choice-criterion-copy">
                        {model.bestForHighlight ? (
                          <HighlightText
                            text={model.bestFor}
                            highlight={model.bestForHighlight}
                          />
                        ) : (
                          model.bestFor
                        )}
                      </p>
                    </div>

                    <div class="engagement-choice-criterion engagement-choice-criterion-rhythm">
                      <p class="engagement-choice-label">
                        Working Rhythm
                      </p>
                      <p class="engagement-choice-criterion-copy">
                        {model.workingRhythm}
                      </p>
                    </div>
                  </div>

                  <div class="engagement-choice-outputs">
                    <p class="engagement-choice-label">
                      What You Leave With
                    </p>
                    <div class="engagement-choice-checklist">
                      {model.deliverables.map((deliverable) => (
                        <div class="engagement-choice-checkline">
                          <Icon
                            name="mdi:check-circle"
                            class="engagement-choice-checkicon"
                            aria-hidden="true"
                          />
                          <span class="engagement-choice-checktext">
                            {deliverable}
                          </span>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              </article>
            ))
          }
        </div>

        <div class="engagement-choice-stack" role="presentation">
          {
            content.models.map((model, index) => (
              <details
                class="engagement-choice-drawer group/model"
                data-model={String(index)}
                open={index === 0}
              >
                <summary
                  class="engagement-choice-toggle"
                  role="button"
                  aria-expanded={index === 0 ? "true" : "false"}
                  aria-controls={`model-content-${index}`}
                >
                  <div class="engagement-choice-toggle-main pointer-events-none">
                    <div class="engagement-choice-index">
                      <span>{String(index + 1).padStart(2, "0")}</span>
                    </div>
                    <div class="engagement-choice-icon transition-transform duration-300 group-hover/model:scale-110 group-open/model:scale-110">
                      <Icon
                        name={modelIcons[index]}
                        class="w-5 h-5 sm:w-6 sm:h-6 text-accent-green"
                        aria-hidden="true"
                      />
                    </div>
                    <div class="engagement-choice-heading">
                      <h3 class="engagement-choice-title">
                        {model.name}
                      </h3>
                      <span class="engagement-choice-subtitle">
                        {model.subheadline}
                      </span>
                    </div>
                    <div class="engagement-choice-toggle-tags pointer-events-none">
                      <span class="engagement-choice-chip">
                        {model.commercialModel}
                      </span>
                      <span class="engagement-choice-chip engagement-choice-chip-time">
                        {model.typicalTimeframe}
                      </span>
                    </div>
                  </div>
                  <div class="engagement-choice-toggle-arrow">
                    <Icon
                      name="mdi:chevron-down"
                      class="engagement-choice-chevron pointer-events-none"
                      aria-hidden="true"
                    />
                  </div>
                </summary>
                <div
                  class="engagement-choice-panel"
                  id={`model-content-${index}`}
                  role="region"
                  aria-label={`${model.name} details`}
                >
                  <div class="engagement-choice-body">
                    <div class="engagement-choice-overview">
                      <div class="engagement-choice-copy">
                        <p class="engagement-choice-eyebrow">
                          What This Model Solves
                        </p>
                        <p class="engagement-choice-description">
                          {model.descriptionHighlight ? (
                            <HighlightText
                              text={model.description}
                              highlight={model.descriptionHighlight}
                            />
                          ) : (
                            model.description
                          )}
                        </p>
                      </div>

                      <aside class="engagement-choice-facts">
                        <div class="engagement-choice-investment">
                          <p class="engagement-choice-label">Investment Range</p>
                          <p class="engagement-choice-investment-value">{model.pricingRange}</p>
                          <p class="engagement-choice-note">
                            Indicative for senior-led scope
                          </p>
                        </div>

                        <dl class="engagement-choice-meta">
                          <div class="engagement-choice-meta-item">
                            <dt class="engagement-choice-label">Commercial Model</dt>
                            <dd class="engagement-choice-meta-value">{model.commercialModel}</dd>
                          </div>

                          <div class="engagement-choice-meta-item">
                            <dt class="engagement-choice-label">Typical Timeframe</dt>
                            <dd class="engagement-choice-meta-value">{model.typicalTimeframe}</dd>
                          </div>
                        </dl>
                      </aside>
                    </div>

                    <div class="engagement-choice-criteria">
                      <div class="engagement-choice-criterion">
                        <p class="engagement-choice-label">
                          Best When
                        </p>
                        <p class="engagement-choice-criterion-copy">
                          {model.bestForHighlight ? (
                            <HighlightText
                              text={model.bestFor}
                              highlight={model.bestForHighlight}
                            />
                          ) : (
                            model.bestFor
                          )}
                        </p>
                      </div>

                      <div class="engagement-choice-criterion engagement-choice-criterion-rhythm">
                        <p class="engagement-choice-label">
                          Working Rhythm
                        </p>
                        <p class="engagement-choice-criterion-copy">
                          {model.workingRhythm}
                        </p>
                      </div>
                    </div>

                    <div class="engagement-choice-outputs">
                      <p class="engagement-choice-label">
                        What You Leave With
                      </p>
                      <div class="engagement-choice-checklist">
                        {model.deliverables.map((deliverable) => (
                          <div class="engagement-choice-checkline">
                            <Icon
                              name="mdi:check-circle"
                              class="engagement-choice-checkicon"
                              aria-hidden="true"
                            />
                            <span class="engagement-choice-checktext">
                              {deliverable}
                            </span>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>
              </details>
            ))
          }
        </div>

        <div
          class="mt-8 text-center"
          data-reveal="fade-up"
          data-reveal-delay="200"
        >
          <p class="text-sm text-theme-secondary opacity-60 italic">
            * Investments are indicative and reflect senior-led delivery for a premium Dubai-based analytics partner. Final pricing depends on scope, complexity, stakeholder load, and delivery model.
          </p>
        </div>
      </div>
</SectionShell>

<script>
  document.addEventListener("astro:page-load", () => {
    const accordionItems = document.querySelectorAll(
      ".engagement-choice-stack .engagement-choice-drawer",
    );

    accordionItems.forEach((item) => {
      const summary = item.querySelector(".engagement-choice-toggle");
      if (!summary) return;

      summary.addEventListener("click", (e) => {
        const isOpening = !item.hasAttribute("open");

        summary.setAttribute("aria-expanded", String(isOpening));

        if (!isOpening) return;

        accordionItems.forEach((otherItem) => {
          if (otherItem !== item && otherItem.hasAttribute("open")) {
            otherItem.removeAttribute("open");
            otherItem
              .querySelector(".engagement-choice-toggle")
              ?.setAttribute("aria-expanded", "false");
          }
        });
      });
    });
  });
</script>
