---
import Card from "@/components/ui/Card.astro";
import HighlightText from "@/components/ui/HighlightText.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import Carousel from "@/components/ui/Carousel.astro";
import SectionShell from "@/components/layouts/SectionShell.astro";
import { createUrl } from "@/utils/url";

interface Props {
  content: {
    title: string;
    description: string;
    descriptionHighlight?: string | string[];
    services: {
      name: string;
      description: string;
      descriptionHighlight?: string | string[];
      link: string;
    }[];
    codeEdge: string;
    codeEdgeHighlight?: string | string[];
  };
}

const { content } = Astro.props;
const services = content?.services?.filter(Boolean) || [];

const serviceIcons = [
  "mdi:layers",
  "mdi:chart-box",
  "mdi:chart-line",
  "mdi:crystal-ball",
  "mdi:book-open-variant",
  "mdi:robot",
  "mdi:brain",
  "mdi:shield-check",
];
---

<SectionShell
  id="services-stages"
  padding="normal"
  background="default"
  gradients={["hero"]}
  contentWidth="screen"
  class="relative services-stages-section"
>
  <div
    data-reveal="fade-down"
    data-reveal-duration="200"
    data-reveal-easing="ease-out"
  >
    <SectionHeader
      title={content?.title || ""}
      subtitle={content?.description || ""}
      highlight="Every Stage"
      subtitleHighlight="Eight"
    />
  </div>
  <div class="hidden lg:grid lg:grid-cols-4 gap-6 sm:gap-8 lg:gap-10 xl:gap-12 mb-10 sm:mb-12 lg:mb-16">
    {services.map((service, index) => (
      <div
        class="overflow-hidden"
        data-reveal="fade-up"
        data-reveal-duration="200"
        data-reveal-delay={50 + index * 40}
        data-reveal-easing="ease-out"
      >
        <Card
          variant="service"
          icon={serviceIcons[index]}
          title={service?.name || ""}
          description={service?.shortDescription || service?.description || ""}
          link={createUrl(service?.link || "#")}
          index={index}
          isCarousel={false}
        />
      </div>
    ))}
  </div>

  <Carousel
    containerId="services-carousel-container"
    trackId="services-carousel-track"
    items={services}
    wrapperClass="services-carousel services-carousel-wrapper"
    breakpoint={1024}
    activateOnDesktop={false}
  >
    {services.map((service, index) => (
      <div
        class="carousel-slide embla__slide"
        data-index={index}
        data-reveal="fade-up"
        data-reveal-duration="200"
        data-reveal-delay={50 + index * 40}
        data-reveal-easing="ease-out"
      >
        <Card
          variant="service"
          icon={serviceIcons[index]}
          title={service?.name || ""}
          description={service?.shortDescription || service?.description || ""}
          link={createUrl(service?.link || "#")}
          index={index}
          isCarousel={true}
        />
      </div>
    ))}
  </Carousel>

  {
    content?.codeEdge && (
      <div
        class="mt-10 sm:mt-12 lg:mt-16"
        data-reveal="fade-up"
        data-reveal-duration="200"
        data-reveal-delay="100"
        data-reveal-easing="ease-out"
      >
        <div class="bg-accent-green/8 border-2 border-accent-green/30 p-8 sm:p-10 lg:p-12 relative overflow-hidden lg:hover:border-accent-green/50 transition-colors duration-300">
          <div class="absolute inset-0 opacity-[0.03] code-edge-pattern"></div>

          <div class="relative z-10">
            <p class="text-body-xl sm:text-[1.1875rem] lg:text-[1.375rem] xl:text-[1.5rem] text-theme-primary leading-relaxed font-body text-center">
              <HighlightText
                text={content.codeEdge}
                highlight={["consistent quality", "common language"]}
                highlightClass="text-accent-green font-bold"
              />
            </p>
          </div>
        </div>
      </div>
    )
  }
</SectionShell>

<style>
  .services-stages-section [data-reveal] {
    will-change: transform, opacity;
  }
</style>

