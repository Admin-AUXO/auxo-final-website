---
import { Icon } from "astro-icon/components";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import Carousel from "@/components/ui/Carousel.astro";
import SectionShell from "@/components/layouts/SectionShell.astro";
import { createUrl } from "@/utils/url";

interface ServiceCardData {
  name: string;
  href: string;
  icon: string;
  category?: string;
  shortDescription: string;
  fit?: string;
  outcome?: string;
}

interface Props {
  services: ServiceCardData[];
}

const { services } = Astro.props;
---

<SectionShell
  id="services-stages"
  padding="normal"
  background="default"
  gradients={["hero"]}
  contentWidth="screen"
  class="relative services-stages-section section-divider"
>
  <div
    data-reveal="fade-down"
    data-reveal-duration="200"
    data-reveal-easing="ease-out"
  >
    <SectionHeader
      title="Browse the service library"
      subtitle="Each service is focused on one kind of operating problem, one kind of buyer pain, and one clearer next step."
      highlight="service library"
    />
  </div>

  <div class="hidden lg:grid services-library-grid services-library-desktop mb-12 lg:mb-16">
    {services.map((service, index) => (
      <a
        href={createUrl(service.href)}
        class="services-library-card group"
        data-reveal="fade-up"
        data-reveal-delay={50 + index * 30}
        data-reveal-duration="200"
        data-reveal-easing="ease-out"
      >
        <div class="services-library-card-top">
          <span class="services-library-category">{service.category}</span>
          <div class="services-library-icon">
            <Icon name={service.icon} class="w-6 h-6 text-accent-green" />
          </div>
        </div>

        <div class="services-library-body">
          <h3 class="services-library-title">{service.name}</h3>
          <p class="services-library-description">{service.shortDescription}</p>
        </div>

        <div class="services-library-meta">
          {service.fit && <p class="services-library-fit">{service.fit}</p>}
          {service.outcome && <p class="services-library-outcome">{service.outcome}</p>}
        </div>

        <span class="services-library-link">
          Explore service
          <Icon
            name="mdi:arrow-right"
            class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300"
          />
        </span>
      </a>
    ))}
  </div>

  <Carousel
    containerId="services-carousel-container"
    trackId="services-carousel-track"
    items={services}
    wrapperClass="services-carousel services-carousel-wrapper services-library-mobile"
  >
    {services.map((service, index) => (
      <div
        class="carousel-slide embla__slide"
        data-index={index}
        data-reveal="fade-up"
        data-reveal-duration="200"
        data-reveal-delay={50 + index * 30}
        data-reveal-easing="ease-out"
      >
        <a href={createUrl(service.href)} class="services-library-card services-library-card-mobile group">
          <div class="services-library-card-top">
            <span class="services-library-category">{service.category}</span>
            <div class="services-library-icon">
              <Icon name={service.icon} class="w-5 h-5 text-accent-green" />
            </div>
          </div>
          <div class="services-library-body">
            <h3 class="services-library-title">{service.name}</h3>
            <p class="services-library-description">{service.shortDescription}</p>
          </div>
          {service.fit && <p class="services-library-fit">{service.fit}</p>}
          <span class="services-library-link">
            Explore service
            <Icon
              name="mdi:arrow-right"
              class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300"
            />
          </span>
        </a>
      </div>
    ))}
  </Carousel>
</SectionShell>
