---
import HeroLayout from "@/components/ui/HeroLayout.astro";
import HeroCTAButton from "@/components/ui/HeroCTAButton.astro";
import HighlightText from "@/components/ui/HighlightText.astro";
import HeroBackdrop from "@/components/effects/HeroBackdrop.astro";

interface Props {
  content: {
    eyebrow: string;
    title: string;
    titleHighlight?: string | string[];
    description: string;
    pills: string[];
    primaryCtaText?: string;
    primaryCtaHref?: string;
    secondaryCtaText?: string;
    secondaryCtaHref?: string;
  };
}

const { content } = Astro.props;
---

<HeroLayout
  id="services-hero"
  scrollHref="#services-chooser"
  scrollText="Find Your Fit"
  scrollAriaLabel="Scroll to find the right service"
>
  <Fragment slot="background">
    <HeroBackdrop mode="sys" showDecorations={true} showAccentLines={true} />
  </Fragment>

  <div class="services-hero-headline mb-6 sm:mb-8 lg:mb-10 w-full">
    <div
      class="services-hero-badge"
      data-reveal="zoom-in"
      data-reveal-duration="200"
      data-reveal-easing="ease-out"
    >
      {content.eyebrow}
    </div>
    <h1
      class="text-h1 font-extrabold leading-tight tracking-tight text-theme-primary transition-colors mb-3 sm:mb-4 lg:mb-5 w-full font-display"
      data-reveal="fade-down"
      data-reveal-duration="200"
      data-reveal-easing="ease-out"
    >
      <HighlightText text={content.title} highlight={content.titleHighlight} />
    </h1>
  </div>

  <div
    class="services-hero-description mb-8 sm:mb-10 lg:mb-12 max-w-[500px] sm:max-w-[600px] lg:max-w-[700px] mx-auto services-hero-follow-content hero-follow-content"
    data-reveal="fade-up"
    data-reveal-delay="50"
    data-reveal-duration="200"
    data-reveal-easing="ease-out"
  >
    <p
      class="text-body-lg sm:text-body-xl text-theme-secondary leading-relaxed transition-colors font-normal opacity-80 font-body"
    >
      {content.description}
    </p>
  </div>

  {
    content.pills?.length > 0 && (
      <div
        class="services-hero-pills"
        data-reveal="fade-up"
        data-reveal-delay="80"
        data-reveal-duration="200"
        data-reveal-easing="ease-out"
      >
        {content.pills.map((pill) => (
          <span class="services-hero-pill">{pill}</span>
        ))}
      </div>
    )
  }

  {
    content.primaryCtaText && content.primaryCtaHref && (
      <div
        class="services-hero-follow-content hero-follow-content"
        data-reveal="fade-up"
        data-reveal-delay="120"
        data-reveal-duration="200"
        data-reveal-easing="ease-out"
      >
        <div class="services-hero-actions">
          <HeroCTAButton
            text={content.primaryCtaText}
            href={content.primaryCtaHref}
            context="hero"
            calendlyText="Schedule a Consultation"
          />
          {
            content.secondaryCtaText && content.secondaryCtaHref && (
              <a href={content.secondaryCtaHref} class="services-hero-secondary-link">
                {content.secondaryCtaText}
              </a>
            )
          }
        </div>
      </div>
    )
  }
</HeroLayout>
