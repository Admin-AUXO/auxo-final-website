---
import HeroLayout from "@/components/ui/HeroLayout.astro";
import HeroCTAButton from "@/components/ui/HeroCTAButton.astro";
import HighlightText from "@/components/ui/HighlightText.astro";
import HeroBackdrop from "@/components/effects/HeroBackdrop.astro";
import { Icon } from "astro-icon/components";
import type { ServicePageDetail } from "@/data/content/service-page-details";

interface Props {
  service: ServicePageDetail;
}

const { service } = Astro.props;

// Mapping service slugs to particle modes for unique contextual backgrounds
const modeMap: Record<string, any> = {
  "foundation-readiness": "network",
  "reporting-reset": "data",
  "performance-diagnostics": "flow",
  "forecasting-lab": "waves",
  "decision-playbooks": "logic",
  "smart-automation": "sys",
  "augmented-intelligence-studio": "ai",
  "autonomy-readiness-review": "expand",
};

const mode = modeMap[service.slug] || "galaxy";
---

<HeroLayout
  id="service-hero"
  class="service-hero-section"
  scrollHref="#service-snapshot"
  scrollText="See Service Fit"
  scrollAriaLabel="Scroll to service fit"
>
  <Fragment slot="background">
    <HeroBackdrop
      mode={mode}
      overlayClass="bg-gradient-to-b from-theme-surface/60 via-theme-surface/40 to-theme-surface"
      topOverlayClass="h-64 bg-gradient-to-b from-theme-primary to-transparent opacity-30"
    />
  </Fragment>

  <div class="service-hero-headline mb-6 sm:mb-8 lg:mb-10 w-full">
    <div
      class="service-hero-badge"
      data-reveal="zoom-in"
      data-reveal-duration="200"
      data-reveal-easing="ease-out"
    >
      <Icon name={service.icon} class="w-4 h-4" />
      <span>{service.category}</span>
    </div>
    <h1
      class="text-h1 font-extrabold leading-tight tracking-tight text-theme-primary transition-colors mb-3 sm:mb-4 lg:mb-5 w-full font-display"
      data-reveal="fade-down"
      data-reveal-duration="200"
      data-reveal-easing="ease-out"
    >
      <HighlightText
        text={service.hero.title}
        highlight={service.hero.title.split(" ").slice(-2)}
        highlightClass="text-accent-green"
      />
    </h1>
    <p
      class="text-body-lg sm:text-body-xl text-theme-secondary leading-relaxed transition-colors font-normal opacity-80 font-body max-w-[500px] sm:max-w-[600px] lg:max-w-[700px] mx-auto"
      data-reveal="fade-up"
      data-reveal-delay="50"
      data-reveal-duration="200"
      data-reveal-easing="ease-out"
    >
      {service.hero.subtitle}
    </p>
  </div>

  <div
    class="service-hero-description mb-8 sm:mb-10 lg:mb-12 max-w-[500px] sm:max-w-[600px] lg:max-w-[700px] mx-auto service-hero-follow-content hero-follow-content"
    data-reveal="fade-up"
    data-reveal-delay="100"
    data-reveal-duration="200"
    data-reveal-easing="ease-out"
  >
    <p
      class="text-body-base sm:text-body-lg text-theme-secondary/90 leading-relaxed font-body"
    >
      <HighlightText
        text={service.hero.description}
        highlight={service.hero.descriptionHighlight || []}
        highlightClass="text-accent-green font-semibold"
      />
    </p>
  </div>

  <div
    class="service-hero-benefits"
    data-reveal="fade-up"
    data-reveal-delay="120"
    data-reveal-duration="200"
    data-reveal-easing="ease-out"
  >
    {service.hero.keyBenefits.map((benefit) => (
      <div class="service-hero-benefit-pill">
        <Icon name="mdi:check-circle-outline" class="w-4 h-4 text-accent-green" />
        <span>{benefit}</span>
      </div>
    ))}
  </div>

  <div
    class="service-hero-follow-content hero-follow-content"
    data-reveal="fade-up"
    data-reveal-delay="160"
    data-reveal-duration="200"
    data-reveal-easing="ease-out"
  >
    <div class="service-hero-actions">
      <HeroCTAButton
        text={service.cta.ctaText}
        href={service.cta.ctaHref}
        context="service"
        calendlyText="Book a Consultation"
      />
      <a href="#service-faq" class="service-hero-secondary-link">
        Review FAQs
      </a>
    </div>
  </div>
</HeroLayout>

