---
import { Icon } from "astro-icon/components";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import SectionShell from "@/components/layouts/SectionShell.astro";
import type { ServicePageDetail } from "@/data/content/service-page-details";

interface Props {
  service: ServicePageDetail;
}

type OutcomeMetric = {
  label: string;
  value: string;
  description: string;
  icon: string;
};

const { service } = Astro.props;
---

<SectionShell
  id="service-outcomes"
  padding="lg"
  background="default"
  gradients={["hero"]}
  contentWidth="6xl"
  class="relative service-outcomes-section section-divider"
>
  <div
    data-reveal="fade-down"
    data-reveal-duration="200"
    data-reveal-easing="ease-out"
  >
    <SectionHeader
      title={service.outcomes.title}
      subtitle={service.outcomes.description}
      subtitleHighlight={service.outcomes.descriptionHighlight}
    />
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-6 lg:gap-8">
    {
      service.outcomes.metrics.map((metric: OutcomeMetric, index: number) => (
        <div
          class="group"
          data-reveal="zoom-in"
          data-reveal-delay={index * 40}
          data-reveal-duration="200"
          data-reveal-easing="ease-out"
        >
          <div class="service-outcome-card h-full relative overflow-hidden transition-colors duration-300 flex flex-col">
            <div class="relative z-10 flex flex-col h-full">
              <div class="service-outcome-card-head">
                <div class="service-outcome-icon">
                  <Icon name={metric.icon} class="w-5 h-5 text-accent-green" />
                </div>
                <span class="service-outcome-eyebrow">{metric.value}</span>
              </div>

              <div class="flex flex-col flex-1 justify-start">
                <h3 class="text-lg sm:text-xl font-bold text-theme-primary mb-2 font-display">
                  {metric.label}
                </h3>
                <p class="text-sm sm:text-base text-theme-secondary/80 leading-relaxed font-body">
                  {metric.description}
                </p>
              </div>
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <div class="mt-12 lg:mt-16 text-center space-y-4">
    <div
      class="inline-flex items-center gap-3 px-6 py-3 bg-accent-green/10 border border-accent-green/20 rounded-full"
    >
      <Icon name="mdi:trending-up" class="w-5 h-5 text-accent-green" />
      <span class="text-sm font-semibold text-accent-green font-body">
        Outcomes tied to operating discipline, not vanity claims
      </span>
    </div>
    <p class="text-xs text-theme-secondary/60 font-body max-w-xl mx-auto leading-relaxed">
      {service.outcomes.note}
    </p>
  </div>
</SectionShell>

