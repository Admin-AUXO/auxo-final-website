---
import { Icon } from "astro-icon/components";
import SectionContainer from "@/components/layouts/SectionContainer.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import HighlightText from "@/components/ui/HighlightText.astro";
import BackgroundDecorations from "@/components/ui/BackgroundDecorations.astro";
import type { ServiceDetail } from "@/data/content/services";

interface Props {
  service: ServiceDetail;
}

type OutcomeMetric = {
  label: string;
  value: string;
  description: string;
};

const { service } = Astro.props;
---

<SectionContainer
  id="service-outcomes"
  padding="lg"
  background="default"
  class="relative service-outcomes-section section-divider"
>
  <BackgroundDecorations gradients={["hero"]} />

  <div class="grid-container relative z-10">
    <div class="col-span-full max-w-6xl mx-auto">
      <div
        data-reveal="fade-down"
        data-reveal-duration="200"
        data-reveal-easing="ease-out"
      >
        <SectionHeader
          title={service.outcomes.title}
          subtitle={service.outcomes.description}
          subtitleHighlight={service.outcomes.descriptionHighlight}
        />
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 lg:gap-8">
        {
          service.outcomes.metrics.map(
            (metric: OutcomeMetric, index: number) => (
              <div
                class="group"
                data-reveal="zoom-in"
                data-reveal-delay={index * 40}
                data-reveal-duration="200"
                data-reveal-easing="ease-out"
              >
                <div class="h-full bg-accent-green/5 border-2 border-accent-green/30 rounded-2xl p-6 lg:p-8 text-center relative overflow-hidden transition-colors duration-300 lg:hover:border-accent-green/50">
                  <div class="relative z-10">
                    <div class="text-3xl lg:text-4xl font-extrabold text-accent-green mb-2 lg:mb-3 font-display">
                      <span class="text-xs lg:text-sm font-semibold text-accent-green/70 block mb-1">
                        Up to
                      </span>
                      {metric.value}
                      <span class="text-accent-green/50 text-lg">*</span>
                    </div>
                    <h3 class="text-h4 font-bold text-theme-primary mb-3 lg:mb-4 font-display">
                      {metric.label}
                    </h3>
                    <p class="text-sm text-theme-secondary leading-relaxed font-body">
                      {metric.description}
                    </p>
                  </div>
                </div>
              </div>
            ),
          )
        }
      </div>

      <div class="mt-12 lg:mt-16 text-center space-y-4">
        <div
          class="inline-flex items-center gap-3 px-6 py-3 bg-accent-green/10 border border-accent-green/20 rounded-full"
        >
          <Icon name="mdi:trending-up" class="w-5 h-5 text-accent-green" />
          <span class="text-sm font-semibold text-accent-green font-body">
            Measurable results backed by data-driven methodologies
          </span>
        </div>
        <p
          class="text-xs text-theme-secondary/60 font-body max-w-xl mx-auto leading-relaxed"
        >
          <span class="text-accent-green/50">*</span> Results may vary based on data
          maturity, organizational readiness, and scope of engagement.
        </p>
      </div>
    </div>
  </div>
</SectionContainer>
