---
import SectionContainer from "@/components/layouts/SectionContainer.astro";
import BackgroundDecorations from "@/components/ui/BackgroundDecorations.astro";

type SectionPadding = "sm" | "normal" | "md" | "lg" | "xl";
type SectionBackground =
  | "default"
  | "card"
  | "surface"
  | "elevated"
  | "accent";
type DecorationGradient = "hero" | "center" | "dual" | "top";
type DecorationPattern = "grid" | "mesh";
type ContentWidth = "full" | "4xl" | "5xl" | "6xl" | "7xl" | "screen";

interface Props {
  id: string;
  padding?: SectionPadding;
  background?: SectionBackground;
  class?: string;
  gradients?: DecorationGradient[];
  patterns?: DecorationPattern[];
  contentClass?: string;
  contentWidth?: ContentWidth;
  style?: string;
}

const {
  id,
  padding = "normal",
  background = "default",
  class: className = "",
  gradients = [],
  patterns = [],
  contentClass = "",
  contentWidth = "screen",
  style,
} = Astro.props;

const contentWidthClasses = {
  full: "",
  "4xl": "max-w-4xl",
  "5xl": "max-w-5xl",
  "6xl": "max-w-6xl",
  "7xl": "max-w-7xl",
  screen: "max-w-[1400px]",
};
---

<SectionContainer
  id={id}
  padding={padding}
  background={background}
  class={`relative ${className}`}
  style={style}
>
  {
    (gradients.length > 0 || patterns.length > 0) && (
      <BackgroundDecorations gradients={gradients} patterns={patterns} />
    )
  }

  <div class="grid-container relative z-10">
    <div
      class:list={[
        "col-span-full mx-auto w-full",
        contentWidthClasses[contentWidth],
        contentClass,
      ]}
    >
      <slot />
    </div>
  </div>
</SectionContainer>
