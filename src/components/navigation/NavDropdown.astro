---
import { Icon } from "astro-icon/components";
import type { NavItem, DropdownItem } from "@/data/content";
import { createUrl } from "@/utils/url";

interface Props {
  item: Omit<NavItem, "_key">;
  index: number;
  isMobile?: boolean;
}

const { item, index, isMobile = false } = Astro.props;
const isModal =
  item.isModal ??
  (item.name?.toLowerCase() === "services" ||
    item.name?.toLowerCase() === "service");

const NAV_BUTTON_BASE =
  "nav-link dropdown-toggle relative px-3 py-2.5 text-sm font-medium text-theme-secondary hover:text-theme-primary transition-all duration-fast rounded-xl hover:bg-theme-surface/60 active:bg-theme-surface/80 flex items-center gap-1.5 min-h-[var(--touch-target-min)] group-hover:text-theme-primary";
const MOBILE_BUTTON_BASE =
  "mobile-dropdown-btn mobile-nav-link block w-full px-5 py-4 min-h-[var(--button-height-lg)] text-base font-semibold text-theme-secondary hover:text-theme-primary active:text-theme-primary rounded-xl transition-all duration-normal touch-manipulation flex items-center justify-between relative group bg-theme-surface/50 hover:bg-theme-surface border border-accent-green/30 hover:border-accent-green/50";
const MOBILE_ACTIVE_BG =
  "mobile-nav-active-bg absolute inset-0 bg-accent-green/10 rounded-xl opacity-0 transition-opacity duration-fast pointer-events-none group-hover:opacity-100";
const MOBILE_ACTIVE_BORDER =
  "mobile-nav-active-border absolute inset-0 rounded-xl border border-accent-green/30 opacity-0 transition-opacity duration-fast pointer-events-none group-hover:opacity-100";
const NAV_ACTIVE_BG =
  "nav-active-bg absolute inset-0 bg-accent-green/5 rounded-xl opacity-0 transition-opacity duration-fast pointer-events-none group-hover:opacity-100";
const ICON_BASE = "w-5 h-5 text-accent-green flex-shrink-0 relative z-10";
const CHEVRON_ICON =
  "w-4 h-4 transition-transform duration-fast dropdown-arrow dropdown-chevron relative z-10 text-accent-green";
const dropdownItems = item.dropdown ?? [];
const contactUrl = createUrl("contact");
const servicesUrl = createUrl("services");
const groupOrder = ["Stabilize", "Optimize", "Scale"];
const groupedDropdownItems = groupOrder
  .map((group) => ({
    group,
    items: dropdownItems.filter((sub: DropdownItem) => sub.group === group),
  }))
  .filter((entry) => entry.items.length > 0);

function getGroupSummary(group: string): string {
  if (group === "Stabilize") {
    return "Fix trust, reporting, and governance issues first.";
  }
  if (group === "Optimize") {
    return "Improve speed, planning, and decision quality.";
  }
  return "Scale throughput with automation and practical AI.";
}
---

{
  isMobile ? (
    <div class="mobile-dropdown-wrapper">
      <button
        type="button"
        class={MOBILE_BUTTON_BASE}
        aria-expanded="false"
        aria-haspopup="true"
        aria-label={`${item.name} menu`}
      >
        <span class="relative z-10">{item.name}</span>
        <Icon
          name="mdi:chevron-down"
          class={`${ICON_BASE} dropdown-arrow-mobile transition-transform duration-fast`}
          aria-hidden="true"
        />
        <span class={MOBILE_ACTIVE_BG} />
        <span class={MOBILE_ACTIVE_BORDER} />
      </button>
      <div class="mobile-dropdown-content hidden">
        <div class="mobile-dropdown-inner">
          <div class="space-y-5">
            {groupedDropdownItems.map(({ group, items }) => (
              <details class="mobile-services-group accordion-item" open={group === "Stabilize"}>
                <summary class="mobile-services-group-summary accordion-summary">
                  <div class="mobile-services-group-copy">
                    <p class="mobile-services-group-label">{group}</p>
                    <p class="mobile-services-group-text">{getGroupSummary(group)}</p>
                  </div>
                  <Icon
                    name="mdi:chevron-down"
                    class="w-4 h-4 text-accent-green transition-transform duration-300"
                    aria-hidden="true"
                  />
                </summary>
                <div class="mobile-dropdown-services-grid">
                  {items.map((sub: DropdownItem) => (
                    <a href={sub.href} class="mobile-service-card group/card">
                      <Icon
                        name={sub.icon}
                        class="w-4 h-4 text-accent-green flex-shrink-0"
                        aria-hidden="true"
                      />
                      <span class="mobile-service-card-content">
                        <span class="mobile-service-card-title">{sub.name}</span>
                        {sub.fit && (
                          <span class="mobile-service-card-fit">{sub.fit}</span>
                        )}
                      </span>
                      <Icon
                        name="mdi:arrow-right"
                        class="mobile-service-card-arrow"
                        aria-hidden="true"
                      />
                    </a>
                  ))}
                </div>
              </details>
            ))}
          </div>

          <a href={item.href} class="mobile-dropdown-view-all group/view">
            <span>View All {item.name}</span>
            <Icon
              name="mdi:arrow-right"
              class="w-3.5 h-3.5 text-accent-green flex-shrink-0 group-hover/view:translate-x-0.5 transition-transform duration-fast"
              aria-hidden="true"
            />
          </a>
        </div>
      </div>
    </div>
  ) : isModal ? (
    <div
      class="relative dropdown-container group"
      data-nav-item={index}
      data-modal-dropdown="true"
    >
      <button
        class={`${NAV_BUTTON_BASE} dropdown-services-toggle services-toggle-button`}
        aria-expanded="false"
        aria-haspopup="true"
        aria-label={`${item.name} menu`}
        data-dropdown-toggle={index}
      >
        <span class="relative z-10 services-button-text">{item.name}</span>
        <Icon
          name="mdi:chevron-down"
          class={`${CHEVRON_ICON} services-chevron-icon`}
          aria-hidden="true"
        />
        <span class={`${NAV_ACTIVE_BG} services-active-bg`} />
      </button>

      <div
        class="dropdown-modal-overlay"
        data-dropdown-overlay={index}
        aria-hidden="true"
      />
      <div
        class="dropdown-modal-menu isolate"
        data-dropdown-menu={index}
        data-dropdown-content
      >
        <div class="dropdown-modal-content-wrapper">
          <div class="dropdown-modal-background">
            <div class="dropdown-bg-gradient-1" />
            <div class="dropdown-bg-gradient-2" />
            <div class="dropdown-bg-pattern" />
          </div>
          <div class="dropdown-modal-content">
            <header class="dropdown-modal-header flex-shrink-0 border-b border-accent-green/30 bg-theme-card">
              <div class="grid-container">
                <div class="col-span-full flex items-center justify-between h-14 sm:h-16 md:h-18 lg:h-18 relative min-w-0 w-full">
                  <p class="text-xs sm:text-sm text-theme-secondary opacity-70 text-left hidden lg:block flex-1">
                    Need help choosing?{" "}
                    <a
                      href={contactUrl}
                      class="text-accent-green hover:underline font-medium transition-colors duration-fast"
                    >
                      Contact our team
                    </a>
                  </p>
                  <div class="hidden lg:flex items-center gap-2 pointer-events-auto flex-shrink-0 ml-auto group/viewall">
                    <a
                      href={servicesUrl}
                      class="flex items-center gap-1.5 text-base font-bold text-theme-primary hover:text-accent-green transition-colors duration-fast"
                      aria-label="View all services"
                    >
                      View All Services
                      <Icon
                        name="mdi:arrow-right"
                        class="w-4 h-4 text-accent-green group-hover/viewall:translate-x-1 transition-transform duration-fast"
                      />
                    </a>
                  </div>
                  <div class="flex flex-col sm:flex-row items-center justify-between gap-3 sm:gap-4 md:gap-6 w-full lg:hidden py-3 sm:py-4">
                    <p class="text-xs sm:text-sm md:text-base text-theme-secondary opacity-70 text-center sm:text-left flex-1 min-w-0">
                      Need help choosing?{" "}
                      <a
                        href={contactUrl}
                        class="text-accent-green hover:underline font-medium transition-colors duration-fast"
                      >
                        Contact our team
                      </a>
                    </p>
                    <div class="flex items-center gap-2 flex-shrink-0 group/viewall-mobile">
                      <a
                        href={servicesUrl}
                        class="flex items-center gap-1.5 text-sm sm:text-base font-bold text-theme-primary hover:text-accent-green transition-colors duration-fast"
                        aria-label="View all services"
                      >
                        View All Services
                        <Icon
                          name="mdi:arrow-right"
                          class="w-4 h-4 text-accent-green group-hover/viewall-mobile:translate-x-1 transition-transform duration-fast"
                        />
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </header>
            <main class="dropdown-modal-content-main overflow-y-auto">
              <div class="w-full max-w-[1520px] mx-auto px-6 sm:px-8 py-4 lg:py-4">
                <div class="dropdown-services-toolbar">
                  <div>
                    <p class="dropdown-services-intro-kicker">Choose by need</p>
                    <p class="dropdown-services-intro-text">
                      Pick the lane that matches the problem. The full library is still available if you want every service at once.
                    </p>
                  </div>
                  <a href={contactUrl} class="dropdown-services-intro-cta group/intro">
                    <span>Need a recommendation?</span>
                    <Icon
                      name="mdi:arrow-right"
                      class="w-4 h-4 text-accent-green group-hover/intro:translate-x-1 transition-transform duration-fast"
                    />
                  </a>
                </div>

                <div class="dropdown-services-group-grid">
                  {groupedDropdownItems.map(({ group, items }) => (
                    <section class="dropdown-services-group-column">
                      <div class="dropdown-services-group-head">
                        <p class="dropdown-services-group-label">{group}</p>
                        <p class="dropdown-services-group-text">{getGroupSummary(group)}</p>
                      </div>

                      <div class="dropdown-services-compact-list">
                        {items.map((sub: DropdownItem, cardIndex: number) => (
                          <a
                            href={sub.href}
                            class={`dropdown-services-compact-card service-card group/card`}
                            data-card-index={cardIndex}
                          >
                            <div class="dropdown-services-compact-icon">
                              <Icon
                                name={sub.icon}
                                class="w-5 h-5 text-accent-green group-hover/card:scale-110 transition-transform duration-500"
                              />
                            </div>

                            <div class="dropdown-services-compact-copy">
                              <h4 class="dropdown-services-compact-title">{sub.name}</h4>
                              {sub.fit && (
                                <p class="dropdown-services-compact-fit">{sub.fit}</p>
                              )}
                            </div>

                            <Icon
                              name="mdi:arrow-right"
                              class="w-4 h-4 text-accent-green/70 group-hover/card:text-accent-green group-hover/card:translate-x-1 transition-all duration-300"
                            />
                          </a>
                        ))}
                      </div>
                    </section>
                  ))}
                </div>
              </div>
            </main>
          </div>
        </div>
      </div>
    </div>
  ) : (
    <div class="relative dropdown-container group" data-nav-item={index}>
      <button
        class={`${NAV_BUTTON_BASE} dropdown-services-toggle`}
        aria-expanded="false"
        aria-haspopup="true"
        aria-label={`${item.name} menu`}
        data-dropdown-toggle={index}
      >
        <span class="relative z-10">{item.name}</span>
        <Icon name="mdi:chevron-down" class={CHEVRON_ICON} aria-hidden="true" />
        <span class={NAV_ACTIVE_BG} />
      </button>

      <div
        class="dropdown-menu isolate"
        data-dropdown-menu={index}
        data-dropdown-content
      >
        <div class="relative">
          <div class="dropdown-menu-arrow" />

          <div class="dropdown-menu-container">
            <div class="space-y-1">
              {dropdownItems.map((sub: DropdownItem) => (
                <a href={sub.href} class="dropdown-menu-item group/item">
                  <div class="dropdown-menu-item-icon">
                    <Icon name={sub.icon} class={ICON_BASE} />
                  </div>

                  <div class="flex-1 min-w-0">
                    <div class="dropdown-menu-item-text">{sub.name}</div>
                  </div>
                  <span class="dropdown-menu-item-bg" />
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  )
}

<script>
  function updateServicesButtonState() {
    const servicesButtons = document.querySelectorAll(
      ".services-toggle-button",
    );

    servicesButtons.forEach((button) => {
      const container = button.closest(".dropdown-container");
      const menu = container?.querySelector("[data-dropdown-menu]");
      const isOpen = menu?.classList.contains("open");

      if (isOpen) {
        button.classList.add("services-modal-open");
        button.setAttribute("aria-expanded", "true");
        button.setAttribute("aria-label", "Close services menu");
      } else {
        button.classList.remove("services-modal-open");
        button.setAttribute("aria-expanded", "false");
        button.setAttribute("aria-label", "Services menu");
      }
    });
  }

  document.addEventListener("dropdown-opened", updateServicesButtonState);
  document.addEventListener("dropdown-closed", updateServicesButtonState);
  updateServicesButtonState();
</script>
